---
// ServicesGrid.astro
import { db, Service, GlobalSetting } from 'astro:db';

const services = await db.select().from(Service);
const rawSettings = await db.select().from(GlobalSetting);
const settings = Object.fromEntries(rawSettings.map(s => [s.key, s.value]));
---
<section id="services" class="section services">
  <div class="container">
    <div class="section-header">
      <h2 class="title-lg" set:html={settings.services_title} />
      <p class="text-muted">{settings.services_desc}</p>
    </div>

    <div class="grid">
      {services.map((s, i) => (
        <div class={`glass-card service-card glass-card-services reveal delay-${(i%3)*100 + 100}`}>
          <div class="icon-wrapper" style={`background: ${s.color}20; color: ${s.color};`}>
            {s.icon}
          </div>
          <h3 style="font-size: 1.3rem; font-weight: 600; line-height: 1.3;">{s.title}</h3>
          <p class="text-muted" style="margin-bottom: 1.5rem; line-height: 1.6; font-size: 0.95rem;">
            {s.desc.length > 90 ? s.desc.substring(0, 90) + '...' : s.desc}
          </p>
          <a href={`/services/${s.id}`} class="service-link" style={`color: ${s.color}`}>Pelajari Lebih Lanjut &rarr;</a>
        </div>
      ))}
    </div>
    <div class="text-center" style="margin-top: 4rem; text-align: center;">
       <a href="/services" class="btn btn-outline">Lihat Semua Layanan</a>
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .section-header .text-muted {
    margin-top: 1rem;
    font-size: 1.125rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .service-card {
    text-align: left;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .icon-wrapper {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    border-radius: 16px;
    margin-bottom: 0.5rem;
  }

  .title-md {
    font-size: 1.5rem;
    font-weight: 600;
  }
</style>
