---
import { db, Message, Service, GlobalSetting } from 'astro:db';

const servicesResult = await db.select().from(Service);
const rawSettings = await db.select().from(GlobalSetting);
const settings = Object.fromEntries(rawSettings.map(s => [s.key, s.value]));

let rawWa = settings.whatsapp_number;
// Auto-correct my previous typo if still in the user's DB
if (!rawWa || rawWa === "0851623219924") {
  rawWa = "085163219924";
}

let waNumber = rawWa.replace(/\D/g, '');
if (waNumber.startsWith('0')) {
  waNumber = '62' + waNumber.substring(1);
}

let success = false;
let error = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const name = data.get("name") as string;
  const email = data.get("email") as string;
  const service = data.get("service") as string;
  const content = data.get("content") as string;
  
  const id = "msg_" + Date.now() + "_" + Math.floor(Math.random() * 1000);
  const created_at = new Date();

  // Handle Fetch/Ajax style POST without full page reload if desired,
  // but since we will redirect to WA, we still save it.
  try {
    await db.insert(Message).values({ id, name, email, service, content, created_at });
    success = true;
  } catch (e) {
    console.error(e);
    error = "Gagal menyimpan pesan ke database.";
  }
}
---

<section id="cta" class="section cta" style="padding-top: 6rem; padding-bottom: 6rem; position: relative;">
  <div class="container" style="max-width: 800px; margin: 0 auto;">
    
    <div class="section-header text-center" style="margin-bottom: 3rem;">
      <h2 class="title-lg">Mulai Proyek <span class="text-gradient">Sekarang</span></h2>
      <p class="text-muted" style="margin-top: 1rem;">Sudah punya wawasan yang mantap? Diskusikan ide Anda bersama Konsultan Digital kami dan raih penawaran esklusif secara gratis.</p>
    </div>

    <div class="glass-card" style="padding: 3rem;">
      
      {success && (
        <div style="background: rgba(16, 185, 129, 0.2); color: #6ee7b7; padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid rgba(16, 185, 129, 0.4); text-align: center;">
          <h3 style="margin-bottom: 0.5rem;">Terima Kasih, {Astro.request.method === 'POST' ? '!' : ''}</h3>
          <p>Pesan Anda telah kami rekam! Tim spesialis kami akan mengevaluasi kebutuhan Anda dan menghubungi kembali secepatnya melalui email.</p>
        </div>
      )}

      {error && (
        <div style="background: rgba(239, 68, 68, 0.2); color: #fca5a5; padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem; text-align: center;">
          {error}
        </div>
      )}

      {!success && (
        <form id="wa-contact-form" method="POST" data-wa={waNumber} style="display: flex; flex-direction: column; gap: 1.5rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group">
              <label class="form-label">Nama Lengkap</label>
              <input type="text" id="wa-name" name="name" class="form-input" required placeholder="Jhon Doe" />
            </div>
            
            <div class="form-group">
              <label class="form-label">Alamat Email Bisnis</label>
              <input type="email" id="wa-email" name="email" class="form-input" required placeholder="nama@perusahaan.com" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Layanan yang Diperlukan</label>
            <select id="wa-service" name="service" class="form-input" required>
              <option value="" disabled selected>Pilih Layanan Konsultasi...</option>
              {servicesResult.map((s) => (
                <option value={s.title}>{s.title}</option>
              ))}
              <option value="Lainnya">Kebutuhan Lainnya</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Jelaskan Ide / Rencana Anda</label>
            <textarea id="wa-content" name="content" class="form-input" rows="5" required placeholder="Ceritakan brief rancangan kebutuhan proyek dan apa target pasar yang ingin Anda tuju..."></textarea>
          </div>

          <button id="wa-submit-btn" type="submit" class="btn btn-primary" style="padding: 1.2rem; font-size: 1.1rem; border-radius: 12px; margin-top: 1rem; width: 100%;">🚀 Kirim Pertanyaan & Request Penawaran</button>
        </form>
      )}
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('wa-contact-form');
  const submitBtn = document.getElementById('wa-submit-btn');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const waNumber = form.getAttribute('data-wa');
      const fd = new FormData(form);
      
      const name = fd.get('name');
      const email = fd.get('email');
      const service = fd.get('service');
      const content = fd.get('content');

      // 1. Send data to server database silently (so it still appears in dashboard)
      const originalText = submitBtn.innerText;
      submitBtn.innerText = 'Mengalihkan ke WhatsApp...';
      submitBtn.style.opacity = '0.7';
      
      try {
        await fetch(window.location.href, {
          method: 'POST',
          body: fd,
        });
      } catch (err) {
        console.error("Gagal menyimpan ke dashboard, tapi pesan akan tetap dilanjut ke WA.", err);
      }

      // 2. Format the WhatsApp Message
      const message = `Halo! Saya tertarik untuk berdiskusi lebih lanjut tentang proyek saya.\n\n*DATA KLIEN*\nNama: ${name}\nEmail: ${email}\nLayanan dibutuhkan: ${service}\n\n*IDE / RENCANA PENGEMBANGAN:*\n${content}`;
      
      // 3. Open WhatsApp
      const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(message)}`;
      window.open(waUrl, '_blank');

      // 4. Reset & Notify User
      submitBtn.innerText = '✅ Terkirim! Lanjut di WhatsApp';
      submitBtn.style.background = '#10b981';
      form.reset();
      
      setTimeout(() => {
        submitBtn.innerText = originalText;
        submitBtn.style.background = '';
        submitBtn.style.opacity = '1';
      }, 5000);
    });
  }
</script>
