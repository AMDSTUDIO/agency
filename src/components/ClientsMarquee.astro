---
// ClientsMarquee.astro
import { db, Client, GlobalSetting, eq } from 'astro:db';

const clientsData = await db.select().from(Client);
const marqueeItems = [...clientsData, ...clientsData, ...clientsData, ...clientsData];

// Ambil aturan tampilan (both, logo, name)
const settingQuery = await db.select().from(GlobalSetting).where(eq(GlobalSetting.key, "client_display_rule"));
const displayRule = settingQuery.length > 0 ? settingQuery[0].value : "both";
---
<div class="marquee-section">
  <p class="marquee-title text-muted">Klien & Mitra Kolaborasi</p>
  <div class="marquee-wrapper">
    <div class="marquee">
      <div class="marquee-content">
        {marqueeItems.map(c => (
          <div class="client-logo" title={c.name}>
            {(displayRule === 'both' || displayRule === 'logo') && (
              <img src={c.logo} alt={c.name} class="marquee-img" />
            )}
            {(displayRule === 'both' || displayRule === 'name') && (
              <span class="marquee-text">{c.name}</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .marquee-wrapper {
    padding: 2.5rem 0;
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
    background: var(--glass-bg);
  }
  
  .marquee {
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    width: 100%;
    /* Gradient masks for smooth fade on edges */
    -webkit-mask-image: linear-gradient(90deg, transparent, #fff 10%, #fff 90%, transparent);
    mask-image: linear-gradient(90deg, transparent, #fff 10%, #fff 90%, transparent);
  }

  .marquee-content {
    display: inline-flex;
    animation: scroll 90s linear infinite;
  }

  .marquee:hover .marquee-content {
    animation-play-state: paused;
  }

  .client-logo {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-muted);
    opacity: 0.6;
    margin: 0 3rem;
    transition: all 0.3s ease;
    cursor: default;
    filter: grayscale(100%);
  }

  .client-logo:hover {
    color: var(--fg);
    opacity: 1;
    filter: grayscale(0%) drop-shadow(0 0 10px var(--glass-border));
    transform: scale(1.1);
  }

  /* When the marquee is hovered, dim the non-hovered logos even more for contrast */
  .marquee:hover .client-logo:not(:hover) {
    opacity: 0.3;
  }

  .marquee-section {
    margin: 4rem 0 0 0;
  }

  .marquee-title {
    display: block;
    width: 100%;
    text-align: center;
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.8;
    font-weight: 600;
  }

  .marquee-img {
    height: 60px;
    width: auto;
    object-fit: contain;
  }

  .marquee-text {
    font-size: 1.1rem;
    font-weight: 600;
    font-family: sans-serif;
    white-space: nowrap;
  }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .marquee-section {
      margin: 1.5rem 0 0 0;
    }
    .marquee-title {
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      opacity: 0.7;
    }
    .marquee-wrapper {
      padding: 1.5rem 0;
    }
    .client-logo {
      margin: 0 1.5rem;
      gap: 0.5rem;
    }
    .marquee-img {
      height: 40px;
    }
    .marquee-text {
      font-size: 0.95rem;
    }
  }
</style>
