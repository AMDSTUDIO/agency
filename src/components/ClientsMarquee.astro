---
// ClientsMarquee.astro
import { db, Client, GlobalSetting, eq } from 'astro:db';

const clientsData = await db.select().from(Client);
const marqueeItems = [...clientsData, ...clientsData, ...clientsData, ...clientsData];

// Ambil aturan tampilan (both, logo, name)
const settingQuery = await db.select().from(GlobalSetting).where(eq(GlobalSetting.key, "client_display_rule"));
const displayRule = settingQuery.length > 0 ? settingQuery[0].value : "both";
---
<div style="margin: 4rem 0 0 0;">
  <p class="marquee-title text-muted" style="display: block; width: 100%; text-align: center; font-size: 0.7rem; margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.8;">Dipercaya oleh berbagai instansi dan perusahaan</p>
  <div class="marquee-wrapper">
    <div class="marquee">
      <div class="marquee-content">
        {marqueeItems.map(c => (
          <div class="client-logo" title={c.name} style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.8rem;">
            {(displayRule === 'both' || displayRule === 'logo') && (
              <img src={c.logo} alt={c.name} style="height: 60px; width: auto; object-fit: contain;" />
            )}
            {(displayRule === 'both' || displayRule === 'name') && (
              <span style="font-size: 0.9rem; font-weight: 500; font-family: sans-serif;">{c.name}</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .marquee-wrapper {
    padding: 2.5rem 0;
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
    background: var(--glass-bg);
  }
  
  .marquee {
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    width: 100%;
    /* Gradient masks for smooth fade on edges */
    -webkit-mask-image: linear-gradient(90deg, transparent, #fff 10%, #fff 90%, transparent);
    mask-image: linear-gradient(90deg, transparent, #fff 10%, #fff 90%, transparent);
  }

  .marquee-content {
    display: inline-flex;
    animation: scroll 30s linear infinite;
  }

  .marquee:hover .marquee-content {
    animation-play-state: paused;
  }

  .client-logo {
    display: flex;
    align-items: center;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-muted);
    opacity: 0.6;
    margin: 0 3rem;
    transition: all 0.3s ease;
    cursor: default;
    filter: grayscale(100%);
  }

  .client-logo:hover {
    color: var(--fg);
    opacity: 1;
    filter: grayscale(0%) drop-shadow(0 0 10px var(--glass-border));
    transform: scale(1.1);
  }

  /* When the marquee is hovered, dim the non-hovered logos even more for contrast */
  .marquee:hover .client-logo:not(:hover) {
    opacity: 0.3;
  }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
