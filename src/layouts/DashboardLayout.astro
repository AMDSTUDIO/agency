---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

const currentRole = Astro.cookies.get("admin_role")?.value || 'Guest';
const currentUser = Astro.cookies.get("admin_username")?.value || 'Guest';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/cd-favicon.svg" />
		<title>{title} | CMS Dashboard</title>
	</head>
	<body class="dashboard-body">
    <div class="bg-mesh"></div>
    
    <div class="dashboard-wrapper">
      <aside class="sidebar glass">
        <div class="sidebar-header">
          <h2 class="text-gradient" style="font-family: var(--font-heading); font-size: 1.5rem;">CMS Panel</h2>
        </div>
        <nav class="sidebar-nav">
          <ul>
            <li><a href="/dashboard">Overview</a></li>
            <li><a href="/dashboard/services">Layanan</a></li>
            <li><a href="/dashboard/portfolio">Portfolio</a></li>
            <li><a href="/dashboard/testimonials">Testimoni</a></li>
            <li><a href="/dashboard/clients">Logo Klien</a></li>
            <li><a href="/dashboard/blog">Website Blog</a></li>
            <li style="margin-top:1rem;"><a href="/dashboard/inbox" style="color: #38bdf8; font-weight:bold;">📥 Kotak Masuk</a></li>
            <li style="margin-top:1rem;"><a href="/dashboard/settings" style="color:var(--primary); font-weight:bold;">⚙️ Pengaturan Situs</a></li>
            <li style="margin-top:0.5rem;">
               <form method="POST" action="/api/logout" style="display:inline;">
                 <button type="submit" style="background:transparent; border:none; color:rgba(239, 68, 68, 0.8); cursor:pointer; font-size:1rem; font-weight:bold;">🚪 Keluar (Logout)</button>
               </form>
            </li>
          </ul>
        </nav>
        <div class="sidebar-footer">
          <a href="/" class="btn btn-outline" style="width: 100%; border-color: rgba(255,255,255,0.1); font-size:0.85rem;">Kembali ke Web</a>
        </div>
      </aside>

      <main class="dashboard-main">
        <header class="dashboard-header glass">
          <h1 class="title-md">{title}</h1>
          <div class="admin-profile" style="display: flex; align-items: center; gap: 1rem;">
            <div style="text-align: right;">
              <span style="display: block; font-weight: 600;">{currentUser}</span>
              <span class="text-muted" style="font-size: 0.8rem;">Role: {currentRole}</span>
            </div>
          </div>
        </header>

        <div class="dashboard-content">
          <slot />
        </div>
      </main>
    </div>
	</body>
</html>

<style>
  .dashboard-body {
    overflow: hidden; /* Prevent body scroll, let content scroll */
  }

  .dashboard-wrapper {
    display: flex;
    height: 100vh;
    margin: 0;
    padding: 0;
    font-family: sans-serif;
  }

  /* Dashboard Mac-OS + Cyber Glassmorphism Layout */
  .dashboard-container {
    display: flex;
    min-height: 100vh;
    background: #090a0f; /* very dark elegant background */
    color: white;
  }

  .dashboard-sidebar {
    width: 280px;
    background: rgba(15, 20, 30, 0.4);
    backdrop-filter: blur(30px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 24px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    position: fixed;
    height: calc(100vh - 40px);
    left: 20px;
    top: 20px;
    z-index: 100;
    overflow: hidden;
  }

  .sidebar-header {
    padding: 2.5rem 1.5rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }

  .sidebar-nav {
    padding: 1.5rem 1rem;
    flex: 1;
    overflow-y: auto;
  }

  .sidebar-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .sidebar-nav a, .sidebar-nav button {
    display: block;
    padding: 0.9rem 1.2rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    border-radius: 12px;
    font-weight: 500;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: left;
    width: 100%;
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.95rem;
    position: relative;
    overflow: hidden;
  }

  .sidebar-nav a:hover, .sidebar-nav button:hover {
    background: rgba(99, 102, 241, 0.15);
    color: #fff;
    border-color: rgba(99, 102, 241, 0.3);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);
    transform: translateX(4px);
  }

  .sidebar-footer {
    padding: 1.5rem;
    background: rgba(0,0,0,0.1);
  }

  .dashboard-main {
    flex: 1;
    margin-left: 320px; /* 280 + 20 margin + 20 space */
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.08), transparent 40%),
                radial-gradient(circle at bottom left, rgba(139, 92, 246, 0.08), transparent 40%);
  }

  .dashboard-header {
    padding: 2rem 3rem;
    background: transparent;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .dashboard-content {
    padding: 1rem 3rem 4rem;
    flex: 1;
  }

  /* Admin Table Styling */
  .table-container {
    width: 100%;
    overflow-x: auto;
    background: rgba(20, 25, 35, 0.6);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 1rem;
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .admin-table th {
    text-align: left;
    padding: 1rem 1.5rem;
    color: var(--text-muted);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    font-weight: 600;
    background: rgba(0,0,0,0.2);
  }

  .admin-table td {
    padding: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    vertical-align: middle;
  }

  .admin-table tr:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .action-btn {
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }

  .action-btn.danger {
    background: rgba(239, 68, 68, 0.2);
    color: #fca5a5;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .action-btn.danger:hover {
    background: rgba(239, 68, 68, 0.4);
  }

  /* Form Elements standard styling for dashboard */
  :global(.form-group) {
    margin-bottom: 1.5rem;
  }
  :global(.form-label) {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  :global(.form-input) {
    width: 100%;
    padding: 0.9rem 1.2rem;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(15, 20, 30, 0.6);
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);
  }
  :global(.form-input:focus) {
    outline: none;
    border-color: rgba(129, 140, 248, 0.8);
    background: rgba(15, 20, 30, 0.8);
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15), inset 0 2px 4px rgba(0,0,0,0.2);
  }
  :global(.table-container) {
    overflow-x: auto;
  }
  :global(.admin-table) {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
  }
  :global(.admin-table th), :global(.admin-table td) {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  :global(.admin-table th) {
    color: var(--text-muted);
    font-weight: 500;
  }
  :global(.action-btn) {
    padding: 0.4rem 0.8rem;
    font-size: 0.8rem;
    border-radius: 6px;
    cursor: pointer;
    border: none;
    background: rgba(255,255,255,0.1);
    color: white;
  }
  :global(.action-btn.danger) {
    background: rgba(239, 68, 68, 0.2);
    color: #fca5a5;
  }
</style>

<style is:global>
  /* Premium Dialog Modal Styles */
  .premium-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.95);
    margin: 0;
    padding: 0;
    width: 90%;
    max-width: 480px;
    background: rgba(15, 20, 30, 0.85);
    backdrop-filter: blur(20px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    color: white;
    box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* When dialog is open */
  .premium-modal[open] {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
    z-index: 1000;
  }

  .premium-modal::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    animation: fade-in 0.3s ease-out forwards;
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .modal-header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .close-btn {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s;
  }
  .close-btn:hover {
    color: #fff;
  }

  .modal-body {
    padding: 2rem;
  }

  .premium-input {
    width: 100%;
    padding: 1rem 1.2rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(0, 0, 0, 0.3);
    color: #fff;
    font-size: 1rem;
    outline: none;
    transition: all 0.3s;
  }
  .premium-input:focus {
    border-color: rgba(129, 140, 248, 0.6);
    background: rgba(0, 0, 0, 0.5);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
  }

  .file-upload-zone {
    display: block;
    position: relative;
    padding: 1.5rem;
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.01);
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
  }
  .file-upload-zone:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(129, 140, 248, 0.5);
  }
  .file-upload-zone input[type="file"] {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    opacity: 0;
    cursor: pointer;
  }
  .upload-text {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .modal-footer {
    margin-top: 2.5rem;
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
  }

  .btn-cancel {
    padding: 0.8rem 1.5rem;
    border-radius: 99px;
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-cancel:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
  }

  .btn-save {
    padding: 0.8rem 2rem;
    border-radius: 99px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    border: none;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 10px 20px -5px rgba(99, 102, 241, 0.4);
    transition: all 0.3s;
  }
  .btn-save:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 25px -5px rgba(99, 102, 241, 0.6);
  }
</style>
