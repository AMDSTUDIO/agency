---
import { db, Service } from 'astro:db';
import Layout from '../../layouts/Layout.astro';

const services = await db.select().from(Service);
---

<Layout title="Semua Layanan Anda" description="Daftar lengkap layanan dari agensi kami.">
  <div class="service-hero" style={`background: url('https://images.unsplash.com/photo-1519389950473-47ba0277781c?q=80&w=2000&auto=format&fit=crop') center/cover no-repeat; height: 60vh; min-height: 400px; display: flex; align-items: flex-end; position: relative;`}>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, var(--hero-overlay) 100%);"></div>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, transparent 100%);"></div>
    <div class="container" style="position: relative; z-index: 2; padding-bottom: 4rem;">
      <span class="category" style={`font-weight: bold; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; display: inline-block; background: var(--bg); padding: 0.5rem 1rem; border-radius: 8px; border: none; color: var(--fg); box-shadow: 0 4px 15px rgba(0,0,0,0.1);`}>Katalog Layanan</span>
      <h1 class="title-xl" style="font-size: clamp(2rem, 5vw, 4rem); max-width: 900px; margin-bottom: 1rem;">Layanan <span class="text-gradient">Terpadu Kami</span></h1>
      <p class="text-muted" style="max-width: 700px; font-size: 1.1rem; line-height: 1.6;">Eksplorasi selengkapnya kapabilitas kami di berbagai disiplin teknologi dan bisnis.</p>
    </div>
  </div>

  <div class="container article-container" style="padding-top: 5rem; padding-bottom: 6rem; max-width: 1200px; margin: 0 auto;">

    <div class="grid" style="display: flex; flex-wrap: wrap; gap: 2rem;">
      {services.map(s => (
        <div class="glass-card service-card" style="flex: 1 1 300px; padding: 2rem; display: flex; flex-direction: column;">
          <div class="icon-wrapper" style={`background: ${s.color}20; color: ${s.color}; width:60px; height:60px; display:flex; align-items:center; justify-content:center; border-radius:12px; font-size:2rem; margin-bottom:1.5rem;`}>
            {s.icon}
          </div>
          <h3 class="title-md" style="margin-bottom: 1rem;">{s.title}</h3>
          <p class="text-muted" style="margin-bottom: 1.5rem; line-height:1.6; flex-grow: 1;">{s.desc.substring(0, 100)}...</p>
          <a href={`/services/${s.id}`} class="btn btn-outline" style={`border-color: ${s.color}; color: ${s.color}; display:inline-block; align-self: flex-start; padding: 0.45rem 1.2rem !important; font-size: 0.85rem !important; font-weight: 600;`}>Selengkapnya</a>
        </div>
      ))}
    </div>
  </div>
</Layout>
