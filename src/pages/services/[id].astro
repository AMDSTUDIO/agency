---
import { db, Service, eq } from 'astro:db';
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

if (!id) return new Response("Not found", { status: 404 });

const services = await db.select().from(Service).where(eq(Service.id, id as string));
const entry = services[0];

if (!entry) return new Response("Not found", { status: 404 });

const bannerImages: Record<string, string> = {
  "project-dev": "https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2000&auto=format&fit=crop",
  "consult-arch": "https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2000&auto=format&fit=crop",
  "consult-biz": "https://images.unsplash.com/photo-1600880292203-757bb62b4baf?q=80&w=2000&auto=format&fit=crop",
  "graphic-design": "https://images.unsplash.com/photo-1561070791-2526d30994b5?q=80&w=2000&auto=format&fit=crop",
  "digital-marketing": "https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2000&auto=format&fit=crop",
  "procurement": "https://images.unsplash.com/photo-1586528116311-ad8ed7c80a71?q=80&w=2000&auto=format&fit=crop",
  "web-dev": "https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=2000&auto=format&fit=crop",
  "live-streaming": "https://images.unsplash.com/photo-1603576302251-ddcffde7c541?q=80&w=2000&auto=format&fit=crop",
  "av-specialist": "https://images.unsplash.com/photo-1603576302251-ddcffde7c541?q=80&w=2000&auto=format&fit=crop"
};

const coverImg = bannerImages[entry.id] || "https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2000&auto=format&fit=crop";
---

<Layout title={entry.title}>
  <div class="service-hero" style={`background: url('${coverImg}') center/cover no-repeat; height: 60vh; min-height: 400px; display: flex; align-items: flex-end; position: relative;`}>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, var(--hero-overlay) 100%);"></div>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, transparent 100%);"></div>
    <div class="container" style="position: relative; z-index: 2; padding-bottom: 4rem;">
      <span class="category" style={`font-weight: bold; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; display: inline-block; background: var(--bg); padding: 0.5rem 1rem; border-radius: 8px; border: none; color: var(--fg); box-shadow: 0 4px 15px rgba(0,0,0,0.1);`}>{entry.icon} Layanan Premium</span>
      <h1 class="title-xl" style="font-size: clamp(2rem, 5vw, 4rem); max-width: 900px; margin-bottom: 1rem;">{entry.title}</h1>
    </div>
  </div>

  <div class="container article-container" style="padding-top: 3rem; padding-bottom: 6rem; max-width: 800px; margin: 0 auto;">
    <a href="/services" class="btn btn-outline back-btn" style="margin-bottom: 3rem;">&larr; Kembali ke Daftar Layanan</a>
    
    <div class="glass-card" style={`border-top: 4px solid ${entry.color}; padding: 3rem; margin-bottom: 3rem;`}>
      <h3 style="font-size: 1.5rem; margin-bottom: 1.5rem; color: var(--fg);">Ikhtisar Ringkas</h3>
      <div class="prose body-text" style="font-size: 1.15rem; line-height: 1.9; color: var(--text-muted);" set:html={entry.desc.replace(/\n\n/g, '<br/><br/>')}></div>
    </div>
    
    <h3 style="font-size: 1.8rem; margin-bottom: 2rem; color: var(--fg); text-align: center;">Nilai Tambah & Kapabilitas</h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; text-align: center; margin-bottom: 4rem;">
      {entry.id === 'live-streaming' ? (
        <>
          <div class="glass-card" style="padding: 1.5rem;">
            <div style={`font-size: 2rem; color: ${entry.color}; margin-bottom: 0.5rem;`}>🎥</div>
            <h4 style="color: var(--fg); margin-bottom: 0.5rem; font-size: 1.1rem;">Kualitas Broadcast Mutakhir</h4>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Siaran multikamera sebening kristal (HD/4K) bebas hambatan.</p>
          </div>
          <div class="glass-card" style="padding: 1.5rem;">
            <div style={`font-size: 2rem; color: ${entry.color}; margin-bottom: 0.5rem;`}>🎛️</div>
            <h4 style="color: var(--fg); margin-bottom: 0.5rem; font-size: 1.1rem;">Audio Jernih Terisolasi</h4>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Pencampuran suara profesional untuk memusnahkan kebisingan sekitar.</p>
          </div>
        </>
      ) : (
        <>
          <div class="glass-card" style="padding: 1.5rem;">
            <div style={`font-size: 2rem; color: ${entry.color}; margin-bottom: 0.5rem;`}>🚀</div>
            <h4 style="color: var(--fg); margin-bottom: 0.5rem; font-size: 1.1rem;">Kecepatan Mutlak</h4>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Optimalisasi siklus rilis yang lebih cepat.</p>
          </div>
          <div class="glass-card" style="padding: 1.5rem;">
            <div style={`font-size: 2rem; color: ${entry.color}; margin-bottom: 0.5rem;`}>🛡️</div>
            <h4 style="color: var(--fg); margin-bottom: 0.5rem; font-size: 1.1rem;">Keamanan Berlapis</h4>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Perlindungan setara standar produk perbankan global.</p>
          </div>
        </>
      )}
    </div>

    <div class="share-box" style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--glass-border); text-align: center;">
      <h4 style="margin-bottom: 1.5rem; color: var(--fg);">Minat dengan layanan ini?</h4>
      <a href="/#cta" class="btn btn-primary" style={`background: linear-gradient(135deg, ${entry.color}, ${entry.color}90); border: none; padding: 1rem 3rem; font-size: 1.1rem; border-radius: 99px;`}>Jadwalkan Konsultasi</a>
    </div>
  </div>
</Layout>

<style is:global>
  .prose p { margin-bottom: 1.5rem; }
  .prose h2, .prose h3 { color: var(--fg); margin-top: 2.5rem; margin-bottom: 1rem; }
</style>
