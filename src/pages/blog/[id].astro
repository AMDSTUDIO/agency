---
import { db, Blog, eq } from 'astro:db';
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

if (!id) return new Response("Not found", { status: 404 });

const articles = await db.select().from(Blog).where(eq(Blog.id, id as string));
const entry = articles[0];

if (!entry) return new Response("Not found", { status: 404 });
---

<Layout title={entry.title}>
  <div class="blog-hero" style={`background: url('${entry.img}') center/cover no-repeat; height: 60vh; min-height: 400px; display: flex; align-items: flex-end; position: relative;`}>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, var(--hero-overlay) 100%);"></div>
    <div class="container" style="position: relative; z-index: 2; padding-bottom: 4rem;">
      <span class="category" style="font-weight: bold; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; display: inline-block; background: var(--bg); padding: 0.5rem 1rem; border-radius: 8px; color: var(--fg); box-shadow: 0 4px 15px rgba(0,0,0,0.1);">{entry.category}</span>
      <h1 class="title-xl" style="font-size: clamp(2.5rem, 6vw, 4rem); max-width: 900px; margin-bottom: 1rem;">{entry.title}</h1>
      <div class="meta" style="display: flex; gap: 2rem; color: var(--fg); opacity: 0.8; font-size: 1rem;">
        <span>Oleh: <strong>{entry.author}</strong></span>
        <span>{entry.date.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      </div>
    </div>
  </div>

  <div class="container article-container" style="padding-top: 3rem; padding-bottom: 6rem; max-width: 800px; margin: 0 auto;">
    <a href="/blog" class="btn btn-outline back-btn" style="margin-bottom: 3rem;">&larr; Kembali ke Daftar Artikel</a>
    
    <div class="prose body-text" style="font-size: 1.15rem; line-height: 1.9; color: var(--text-muted);" set:html={entry.content.replace(/\n\n/g, '<br/><br/>')}></div>
    
    <div class="share-box" style="margin-top: 5rem; padding-top: 2rem; border-top: 1px solid var(--glass-border); display: flex; justify-content: space-between; align-items: center;">
      <span style="font-weight: bold; color: var(--fg);">Bagikan Artikel Ini:</span>
      <div style="display: flex; gap: 1rem;">
        <a href="#" class="btn btn-outline" style="border-radius: 50%; width: 45px; height: 45px; padding: 0; display: inline-flex;">X</a>
        <a href="#" class="btn btn-outline" style="border-radius: 50%; width: 45px; height: 45px; padding: 0; display: inline-flex;">in</a>
        <a href="#" class="btn btn-outline" style="border-radius: 50%; width: 45px; height: 45px; padding: 0; display: inline-flex;">f</a>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .prose p { margin-bottom: 1.5rem; }
  .prose h2, .prose h3 { color: var(--fg); margin-top: 2.5rem; margin-bottom: 1rem; }
  .prose ul, .prose ol { margin-bottom: 1.5rem; padding-left: 2rem; }
</style>
