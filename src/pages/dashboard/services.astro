---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Service, eq } from 'astro:db';

// Process Form Submissions (Create or Delete)
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Service).where(eq(Service.id, id));
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const desc = formData.get('desc') as string;
    const icon = formData.get('icon') as string;
    const color = formData.get('color') as string || 'hsl(200, 80%, 50%)';

    try {
      await db.insert(Service).values({ id, title, desc, icon, color });
    } catch (e) {
      console.error(e);
      // Handle error natively
    }
  }
}

// Fetch all from DB
const services = await db.select().from(Service);
---

<DashboardLayout title="Manajemen Layanan">
  
  <div class="dashboard-action-bar" style="margin-bottom: 2rem;">
    <details class="glass-card add-new-details">
      <summary class="add-new-summary">
        <span style="display: flex; align-items: center; gap: 0.5rem;"><span style="font-size: 1.2rem;">✨</span> Tambah Layanan Baru</span>
        <span class="indicator text-muted">Buka formulir &darr;</span>
      </summary>
      
      <div class="add-new-content">
        <form method="POST">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
            <div class="form-group">
              <label class="form-label">ID / Slug (Unik, huruf & strip)</label>
              <input type="text" name="id" class="form-input" placeholder="contoh: cloud-hosting" required />
            </div>

            <div class="form-group">
              <label class="form-label">Nama Layanan</label>
              <input type="text" name="title" class="form-input" placeholder="Contoh: Cloud Hosting & Server" required />
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Deskripsi Lengkap</label>
              <textarea name="desc" class="form-input" rows="3" placeholder="Jelaskan penawaran layanan inti kepada klien..." required></textarea>
            </div>

            <div class="form-group">
              <label class="form-label">Ikon (Emoji/Teks Kode)</label>
              <input type="text" name="icon" class="form-input" placeholder="☁️" required />
            </div>
            
            <div class="form-group">
              <label class="form-label">Tema Warna Biasa (CSS format)</label>
              <input type="text" name="color" class="form-input" value="hsl(200, 80%, 50%)" required />
            </div>
          </div>

          <div style="margin-top: 1.5rem; text-align: right;">
            <button type="submit" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">Simpan Layanan Baru</button>
          </div>
        </form>
      </div>
    </details>
  </div>
    
  <div>
    <h3 style="margin-bottom: 1.5rem; font-size: 1.2rem; font-weight: 600;">Direktori Layanan Terdaftar</h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
      {services.map(s => (
        <div class="data-card glass-card" style="padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease;">
          <div>
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
              <div style={`background:${s.color || 'var(--primary)'}20; border: 1px solid ${s.color || 'var(--primary)'}40; border-radius: 12px; font-size: 2rem; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;`}>
                {s.icon}
              </div>
              <span style="font-family: monospace; font-size: 0.8rem; background: rgba(0,0,0,0.3); padding: 0.3rem 0.6rem; border-radius: 99px; color: var(--text-muted); border: 1px solid rgba(255,255,255,0.05);">{s.id}</span>
            </div>
            
            <h4 style="font-size: 1.15rem; font-weight: 600; color: #fff; margin-bottom: 0.5rem;">{s.title}</h4>
            <p class="text-muted" style="font-size: 0.9rem; line-height: 1.5;">{s.desc.length > 120 ? s.desc.substring(0, 120) + '...' : s.desc}</p>
          </div>
          
          <div style="margin-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.2rem; display: flex; justify-content: flex-end;">
            <form method="POST" style="margin:0;" onsubmit="return confirm('Data layanan ini akan dihapus permanen. Lanjutkan?');">
              <input type="hidden" name="action" value="delete" />
              <input type="hidden" name="id" value={s.id} />
              <button type="submit" class="action-btn danger" style="width: 100%; border-radius: 8px;">🗑️ Hapus Layanan</button>
            </form>
          </div>
        </div>
      ))}
    </div>

    {services.length === 0 && (
      <div class="glass-card" style="text-align:center; color: var(--text-muted); padding: 4rem 2rem; border-style: dashed;">
        <span style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 1rem;">📦</span>
        Belum ada entri layanan. Silakan tambahkan layanan pertama Anda.
      </div>
    )}
  </div>
</DashboardLayout>

<style>
  .add-new-details {
    padding: 0;
    transition: all 0.3s ease;
  }
  .add-new-details[open] {
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .add-new-summary {
    list-style: none;
    padding: 1.5rem 2rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    user-select: none;
  }
  .add-new-summary::-webkit-details-marker {
    display: none;
  }
  .add-new-content {
    padding: 0 2rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: 0.5rem;
    padding-top: 1.5rem;
    animation: slideDown 0.3s ease-out forwards;
  }
  
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
