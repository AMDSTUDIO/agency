---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Service, eq } from 'astro:db';

// Process Form Submissions (Create or Delete)
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Service).where(eq(Service.id, id));
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const desc = formData.get('desc') as string;
    const icon = formData.get('icon') as string;
    const color = formData.get('color') as string || 'hsl(200, 80%, 50%)';

    try {
      await db.insert(Service).values({ id, title, desc, icon, color });
    } catch (e) {
      console.error(e);
      // Handle error natively
    }
  }
}

// Fetch all from DB
const services = await db.select().from(Service);
---

<DashboardLayout title="Manajemen Layanan">
  
  <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem;">
    
    <div class="glass-card">
      <h3 class="title-md" style="margin-bottom: 1.5rem; font-size: 1.2rem;">Tambah Layanan Baru</h3>
      
      <form method="POST">
        <input type="hidden" name="action" value="create"/>
        
        <div class="form-group">
          <label class="form-label">ID / Slug (Unik, huruf & strip)</label>
          <input type="text" name="id" class="form-input" required />
        </div>

        <div class="form-group">
          <label class="form-label">Nama Layanan</label>
          <input type="text" name="title" class="form-input" required />
        </div>

        <div class="form-group">
          <label class="form-label">Deskripsi</label>
          <textarea name="desc" class="form-input" rows="3" required></textarea>
        </div>

        <div style="display:flex; gap:1rem;">
          <div class="form-group" style="flex:1;">
            <label class="form-label">Ikon (Emoji/Teks)</label>
            <input type="text" name="icon" class="form-input" required />
          </div>
          <div class="form-group" style="flex:1;">
            <label class="form-label">Tema Warna (hsl)</label>
            <input type="text" name="color" class="form-input" placeholder="hsl(199, 89%, 48%)" required />
          </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%;">Simpan Layanan</button>
      </form>
    </div>

    <div class="glass-card table-container">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Layanan</th>
            <th>Ikon</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          {services.map(s => (
            <tr>
              <td>{s.id}</td>
              <td><strong>{s.title}</strong><br/><small class="text-muted">{s.desc}</small></td>
              <td><span style={`background:${s.color}20; padding:0.5rem; border-radius:5px;`}>{s.icon}</span></td>
              <td>
                <form method="POST" style="display:inline;" onsubmit="return confirm('Hapus layanan ini?');">
                  <input type="hidden" name="action" value="delete"/>
                  <input type="hidden" name="id" value={s.id}/>
                  <button class="action-btn danger">Hapus</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>

</DashboardLayout>
