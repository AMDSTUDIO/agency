---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Service, eq } from 'astro:db';
import fs from 'node:fs';
import path from 'node:path';

async function processFile(file: File | null, defaultUrl: string) {
  if (file && file.size > 0 && file.name) {
    const dir = path.join(process.cwd(), 'public', 'uploads');
    if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
    const ext = file.name.split('.').pop() || 'png';
    const name = `${Date.now()}-${Math.round(Math.random()*1000)}.${ext}`;
    const buffer = Buffer.from(await file.arrayBuffer());
    fs.writeFileSync(path.join(dir, name), buffer);
    return `/uploads/${name}`;
  }
  return defaultUrl;
}

// Process Form Submissions (Create or Delete)
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Service).where(eq(Service.id, id));
  } else if (act === 'update') {
    const original_id = formData.get('original_id') as string;
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const desc = formData.get('desc') as string;
    const color = formData.get('color') as string || '#6366f1';
    
    const iconUrl = formData.get('icon_url') as string || (formData.get('existing_icon') as string) || '';
    const iconFile = formData.get('icon_file') as File | null;
    const icon = await processFile(iconFile, iconUrl);

    const imgUrl = formData.get('img_url') as string || (formData.get('existing_img') as string) || '';
    const imgFile = formData.get('img_file') as File | null;
    const img = await processFile(imgFile, imgUrl);

    const capabilities = formData.get('capabilities') as string || '';

    try {
      await db.update(Service).set({ id, title, desc, icon, color, img, capabilities }).where(eq(Service.id, original_id));
    } catch (e) {
      console.error(e);
    }
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const desc = formData.get('desc') as string;
    const color = formData.get('color') as string || '#6366f1';
    
    const iconUrl = formData.get('icon_url') as string || '';
    const iconFile = formData.get('icon_file') as File | null;
    const icon = await processFile(iconFile, iconUrl);

    const imgUrl = formData.get('img_url') as string || '';
    const imgFile = formData.get('img_file') as File | null;
    const img = await processFile(imgFile, imgUrl);

    const capabilities = formData.get('capabilities') as string || '';

    try {
      await db.insert(Service).values({ id, title, desc, icon, color, img, capabilities });
    } catch (e) {
      console.error(e);
    }
  }
}

// Fetch all from DB
const services = await db.select().from(Service);
---

<DashboardLayout title="Manajemen Layanan">
  
  <div class="dashboard-action-bar" style="margin-bottom: 2rem;">
    <!-- Tambah Layanan Button -->
    <div class="glass-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-radius: 16px;">
      <div>
        <h4 style="margin: 0 0 0.5rem 0; font-weight: 600;">✨ Tambah Layanan Baru</h4>
        <p class="text-muted" style="margin: 0; font-size: 0.9rem;">Tawarkan keunggulan baru dari agensi Anda.</p>
      </div>
      <button onclick="document.getElementById('add_modal').showModal()" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; font-weight: 600;">
        ➕ Tambah Layanan
      </button>
    </div>

    <!-- Add Layanan Modal -->
    <dialog id="add_modal" class="premium-modal" style="max-width: 800px; width: 90%;">
      <div class="modal-header">
        <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; background: linear-gradient(135deg, #fff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Layanan Baru</h3>
        <button type="button" class="close-btn" onclick="document.getElementById('add_modal').close()">&times;</button>
      </div>
      
      <div class="modal-body">
        <form method="POST" enctype="multipart/form-data">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
              <div class="form-group" style="margin: 0;">
                <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Nama Layanan</label>
                <input type="text" id="service_title_add" name="title" class="premium-input" placeholder="Contoh: VPS Murah" required />
              </div>
              <div class="form-group" style="margin: 0;">
                <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Kode ID (Auto-Slug)</label>
                <input type="text" id="service_slug_add" name="id" class="premium-input" placeholder="contoh: vps-murah" required />
              </div>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
              <div class="form-group" style="margin: 0;">
                <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Ikon (Emoji/URL/Upload)</label>
                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                  <input type="text" name="icon_url" class="premium-input" placeholder="Ketik Emoji..." />
                  <div style="background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.15); padding: 0.6rem; border-radius: 8px;">
                    <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.3rem;">Atau Unggah Ikon Komputer:</span>
                    <input type="file" name="icon_file" accept="image/*" style="font-size: 0.85rem; color: #fff; width: 100%;" />
                  </div>
                </div>
              </div>
              <div class="form-group" style="margin: 0;">
                <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Warna Tema</label>
                <input type="color" name="color" class="premium-input" style="padding: 0.2rem; height: 48px; cursor: pointer;" value="#6366f1" required />
              </div>
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Unggah Gambar Banner</label>
              <div style="background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.15); padding: 0.6rem; border-radius: 8px;">
                <input type="file" name="img_file" accept="image/*" style="font-size: 0.85rem; color: #fff; width: 100%;" required />
              </div>
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Deskripsi Lengkap</label>
              <textarea name="desc" class="premium-input" rows="3" placeholder="Penjelasan mengenai layanan..." required></textarea>
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Nilai Tambah & Kapabilitas</label>
              <input type="hidden" name="capabilities" id="caps_hidden_add" />
              <div id="caps_list_add" style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 0.5rem;"></div>
              <button type="button" onclick="addCapUI('caps_list_add', 'caps_hidden_add')" class="btn" style="background: rgba(99,102,241,0.1); color: #818cf8; width: 100%; border: 1px dashed #818cf8; border-radius: 8px; padding: 0.8rem;">+ Tambah Kapabilitas Baru</button>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn-cancel" onclick="document.getElementById('add_modal').close()">Batal</button>
            <button type="submit" class="btn-save">Simpan Layanan</button>
          </div>
        </form>
      </div>
    </dialog>
  </div>
    
  <div>
    <h3 style="margin-bottom: 1.5rem; font-size: 1.2rem; font-weight: 600;">Direktori Layanan Terdaftar</h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
      {services.map(s => (
        <div class="data-card glass-card" style="padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease;">
          <div>
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
              <div style={`background:${s.color || 'var(--primary)'}20; border: 1px solid ${s.color || 'var(--primary)'}40; border-radius: 12px; font-size: 2rem; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;`}>
                {s.icon}
              </div>
              <span style="font-family: monospace; font-size: 0.8rem; background: rgba(0,0,0,0.3); padding: 0.3rem 0.6rem; border-radius: 99px; color: var(--text-muted); border: 1px solid rgba(255,255,255,0.05);">{s.id}</span>
            </div>
            
            <h4 style="font-size: 1.15rem; font-weight: 600; color: #fff; margin-bottom: 0.5rem;">{s.title}</h4>
            <p class="text-muted" style="font-size: 0.9rem; line-height: 1.5;">{s.desc.length > 120 ? s.desc.substring(0, 120) + '...' : s.desc}</p>
          </div>
          
          <div style="margin-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.2rem; display: flex; gap: 0.5rem;">
            <button type="button" onclick={`document.getElementById('edit_modal_${s.id}').showModal()`} class="action-btn" style="width: 100%; border-radius: 8px; padding: 0.6rem; background: rgba(99,102,241,0.1); color: #818cf8; border: 1px solid rgba(99,102,241,0.2);">✏️ Edit</button>
            <form method="POST" style="margin:0; flex:1;" onsubmit="return confirm('Data layanan ini akan dihapus permanen. Lanjutkan?');">
              <input type="hidden" name="action" value="delete" />
              <input type="hidden" name="id" value={s.id} />
              <button type="submit" class="action-btn danger" style="width: 100%; border-radius: 8px; height: 100%; padding: 0.6rem;">🗑️ Hapus</button>
            </form>

            <dialog id={`edit_modal_${s.id}`} class="premium-modal" style="max-width: 800px; width: 90%;">
              <div class="modal-header">
                <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; background: linear-gradient(135deg, #fff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Ubah Layanan</h3>
                <button type="button" class="close-btn" onclick={`document.getElementById('edit_modal_${s.id}').close()`}>&times;</button>
              </div>
              
              <div class="modal-body">
                <form method="POST" enctype="multipart/form-data">
                  <input type="hidden" name="action" value="update"/>
                  <input type="hidden" name="original_id" value={s.id}/>
                  <input type="hidden" name="existing_icon" value={s.icon}/>
                  <input type="hidden" name="existing_img" value={s.img || ''}/>
                  
                  <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Nama Layanan</label>
                        <input type="text" name="title" class="premium-input" value={s.title} required />
                      </div>
                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Kode ID</label>
                        <input type="text" name="id" class="premium-input" value={s.id} required />
                      </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Ikon (Emoji/URL/Upload)</label>
                        <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                          <input type="text" name="icon_url" class="premium-input" placeholder="Emoji..." value={s.icon && !s.icon.startsWith('/') && !s.icon.startsWith('http') ? s.icon : ''} />
                          <div style="background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.15); padding: 0.6rem; border-radius: 8px;">
                            <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.3rem;">Atau Unggah Ikon Beda (Abaikan jika tetap):</span>
                            <input type="file" name="icon_file" accept="image/*" style="font-size: 0.85rem; color: #fff; width: 100%;" />
                          </div>
                        </div>
                      </div>
                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Warna Tema</label>
                        <input type="color" name="color" class="premium-input" style="padding: 0.2rem; height: 48px; cursor: pointer;" value={s.color.startsWith('#') ? s.color : '#6366f1'} required />
                      </div>
                    </div>

                    <div class="form-group" style="margin: 0;">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Ganti Gambar Banner (Biarkan jika sama)</label>
                      <div style="background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.15); padding: 0.6rem; border-radius: 8px;">
                        <input type="file" name="img_file" accept="image/*" style="font-size: 0.85rem; color: #fff; width: 100%;" />
                      </div>
                    </div>

                    <div class="form-group" style="margin: 0;">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Deskripsi Lengkap</label>
                      <textarea name="desc" class="premium-input" rows="3" required>{s.desc}</textarea>
                    </div>

                    <div class="form-group" style="margin: 0;">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Nilai Tambah & Kapabilitas</label>
                      <input type="hidden" name="capabilities" id={`caps_hidden_${s.id}`} value={s.capabilities || ''} />
                      <div id={`caps_list_${s.id}`} style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 0.5rem;"></div>
                      <button type="button" onclick={`addCapUI('caps_list_${s.id}', 'caps_hidden_${s.id}')`} class="btn" style="background: rgba(99,102,241,0.1); color: #818cf8; width: 100%; border: 1px dashed #818cf8; border-radius: 8px; padding: 0.8rem;">+ Tambah Kapabilitas Baru</button>
                    </div>
                  </div>

                  <div class="modal-footer">
                    <button type="button" class="btn-cancel" onclick={`document.getElementById('edit_modal_${s.id}').close()`}>Batal</button>
                    <button type="submit" class="btn-save">Simpan Perubahan</button>
                  </div>
                </form>
              </div>
            </dialog>
          </div>
        </div>
      ))}
    </div>

    {services.length === 0 && (
      <div class="glass-card" style="text-align:center; color: var(--text-muted); padding: 4rem 2rem; border-style: dashed;">
        <span style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 1rem;">📦</span>
        Belum ada entri layanan. Silakan tambahkan layanan pertama Anda.
      </div>
    )}
  </div>
</DashboardLayout>

<script is:inline>
  // UI Builder untuk Kapabilitas
  function encodeCapRow(icon, title, desc) {
    return `${(icon||'').replace(/\|/g,'')} | ${(title||'').replace(/\|/g,'')} | ${(desc||'').replace(/\|/g,'')}`;
  }

  function addCapUI(targetId, hiddenId, icon='', title='', desc='') {
    const list = document.getElementById(targetId);
    if (!list) return;

    const row = document.createElement('div');
    row.style = "display: flex; gap: 0.5rem; align-items: stretch; background: rgba(0,0,0,0.2); padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);";
    
    // Icon input
    const elIcon = document.createElement('input');
    elIcon.type = "text"; elIcon.value = icon; elIcon.className = "premium-input"; elIcon.style = "width: 50px; padding: 0.4rem; text-align: center;"; elIcon.placeholder = "⚙️";
    elIcon.oninput = () => updateCap(targetId, hiddenId);

    // Title input
    const elTitle = document.createElement('input');
    elTitle.type = "text"; elTitle.value = title; elTitle.className = "premium-input"; elTitle.style = "flex: 1; padding: 0.4rem;"; elTitle.placeholder = "Judul Kapabilitas";
    elTitle.oninput = () => updateCap(targetId, hiddenId);

    // Desc input
    const elDesc = document.createElement('input');
    elDesc.type = "text"; elDesc.value = desc; elDesc.className = "premium-input"; elDesc.style = "flex: 2; padding: 0.4rem;"; elDesc.placeholder = "Deskripsi Singkat...";
    elDesc.oninput = () => updateCap(targetId, hiddenId);

    // Del btn
    const elDel = document.createElement('button');
    elDel.type = "button"; elDel.className = "btn danger"; elDel.innerText = "❌"; elDel.style = "padding: 0.4rem; border-radius: 8px;";
    elDel.onclick = function() { row.remove(); updateCap(targetId, hiddenId); };

    row.appendChild(elIcon);
    row.appendChild(elTitle);
    row.appendChild(elDesc);
    row.appendChild(elDel);

    list.appendChild(row);
    updateCap(targetId, hiddenId);
  }

  function updateCap(targetId, hiddenId) {
    const list = document.getElementById(targetId);
    const hidden = document.getElementById(hiddenId);
    if (!list || !hidden) return;

    let lines = [];
    Array.from(list.children).forEach(row => {
      const inputs = row.querySelectorAll('input');
      if (inputs.length === 3) {
        lines.push(`${inputs[0].value.trim()} | ${inputs[1].value.trim()} | ${inputs[2].value.trim()}`);
      }
    });
    hidden.value = lines.join('\n');
  }

  // Pre-fill Edit Modals with capabilities safely via attribute inspection 
  // We attach a load event to parse hidden inputs on page load
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("input[id^='caps_hidden_']").forEach(hidden => {
      const targetId = hidden.id.replace('caps_hidden_', 'caps_list_');
      const val = hidden.value;
      
      // Clear container first just in case
      const c = document.getElementById(targetId);
      if(c) c.innerHTML = '';
      
      if (val) {
        val.split('\n').forEach(line => {
          const p = line.split('|').map(s => s.trim());
          if (p.length >= 3) addCapUI(targetId, hidden.id, p[0], p[1], p[2]);
        });
      }
    });

    // Auto-Slug Add Logic
    const titleInput = document.getElementById('service_title_add');
    const slugInput = document.getElementById('service_slug_add');
    if (titleInput && slugInput) {
      titleInput.addEventListener('input', function() {
        slugInput.value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
      });
    }
  });
</script>


