---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Testimonial, eq } from 'astro:db';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Testimonial).where(eq(Testimonial.id, id));
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const name = formData.get('name') as string;
    const role = formData.get('role') as string;
    const avatar = formData.get('avatar') as string;
    const content = formData.get('content') as string;

    try {
      await db.insert(Testimonial).values({ id, name, role, avatar, content });
    } catch (e) {
      console.error(e);
    }
  }
}

const testimonials = await db.select().from(Testimonial);
---

<DashboardLayout title="Manajemen Testimoni">
  <div class="dashboard-action-bar" style="margin-bottom: 2rem;">
    <details class="glass-card add-new-details">
      <summary class="add-new-summary">
        <span style="display: flex; align-items: center; gap: 0.5rem;"><span style="font-size: 1.2rem;">✨</span> Tambah Testimoni Klien</span>
        <span class="indicator text-muted">Buka formulir &darr;</span>
      </summary>
      
      <div class="add-new-content">
        <form method="POST">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
            <div class="form-group">
              <label class="form-label">ID Unik (contoh: pt-abcd)</label>
              <input type="text" name="id" class="form-input" required />
            </div>

            <div class="form-group">
              <label class="form-label">Nama Klien / Perwakilan</label>
              <input type="text" name="name" class="form-input" required />
            </div>

            <div class="form-group">
              <label class="form-label">Jabatan & Nama Perusahaan</label>
              <input type="text" name="role" class="form-input" required />
            </div>

            <div class="form-group">
              <label class="form-label">URL Foto / Avatar Klien</label>
              <input type="url" name="avatar" class="form-input" required />
            </div>
            
            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Teks Ulasan (Testimoni Panjang)</label>
              <textarea name="content" class="form-input" rows="4" required></textarea>
            </div>
          </div>

          <div style="margin-top: 1.5rem; text-align: right;">
            <button type="submit" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">Simpan Testimoni</button>
          </div>
        </form>
      </div>
    </details>
  </div>

  <div>
    <h3 style="margin-bottom: 1.5rem; font-size: 1.2rem; font-weight: 600;">Data Testimoni Klien</h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
      {testimonials.map(t => (
        <div class="data-card glass-card" style="padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease;">
          <div>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
              <img src={t.avatar} alt={t.name} style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.1); box-shadow: 0 4px 10px rgba(0,0,0,0.3);" />
              <div>
                <h4 style="font-size: 1.1rem; font-weight: 600; color: #fff; margin-bottom: 0.2rem;">{t.name}</h4>
                <div class="text-muted" style="font-size: 0.85rem;">{t.role}</div>
              </div>
            </div>
            
            <div style="position: relative; padding: 1rem; background: rgba(0,0,0,0.2); border-radius: 12px; margin-bottom: 1.5rem;">
              <span style="position: absolute; top: -10px; left: 10px; font-size: 2rem; color: rgba(129, 140, 248, 0.4); font-family: serif; line-height: 1;">"</span>
              <p style="color: rgba(255,255,255,0.9); font-size: 0.95rem; font-style: italic; line-height: 1.6; position: relative; z-index: 1;">
                {t.content.length > 150 ? t.content.substring(0, 150) + '...' : t.content}
              </p>
            </div>
          </div>
          
          <div style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.2rem; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-family: monospace; font-size: 0.75rem; color: var(--text-muted); opacity: 0.5;">ID: {t.id}</span>
            <form method="POST" style="margin:0;" onsubmit="return confirm('Hapus permanen testimoni klien ini?');">
              <input type="hidden" name="action" value="delete"/>
              <input type="hidden" name="id" value={t.id}/>
              <button class="action-btn danger" style="border-radius: 8px; padding: 0.4rem 1rem;">Hapus</button>
            </form>
          </div>
        </div>
      ))}
    </div>

    {testimonials.length === 0 && (
      <div class="glass-card" style="text-align:center; color: var(--text-muted); padding: 4rem 2rem; border-style: dashed;">
        <span style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 1rem;">💬</span>
        Belum ada entri testimoni. Silakan tambahkan testimoni klien pertama Anda.
      </div>
    )}
  </div>
</DashboardLayout>

<style>
  .add-new-details {
    padding: 0;
    transition: all 0.3s ease;
  }
  .add-new-details[open] {
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .add-new-summary {
    list-style: none;
    padding: 1.5rem 2rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    user-select: none;
  }
  .add-new-summary::-webkit-details-marker {
    display: none;
  }
  .add-new-content {
    padding: 0 2rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: 0.5rem;
    padding-top: 1.5rem;
    animation: slideDown 0.3s ease-out forwards;
  }
  
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
