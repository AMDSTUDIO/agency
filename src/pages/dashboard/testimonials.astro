---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Testimonial, eq } from 'astro:db';
import fs from 'node:fs';
import path from 'node:path';

async function processFile(file: File | null, defaultUrl: string) {
  if (file && file.size > 0 && file.name) {
    const dir = path.join(process.cwd(), 'public', 'uploads');
    if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
    const ext = file.name.split('.').pop() || 'png';
    const name = `${Date.now()}-${Math.round(Math.random()*1000)}.${ext}`;
    const buffer = Buffer.from(await file.arrayBuffer());
    fs.writeFileSync(path.join(dir, name), buffer);
    return `/uploads/${name}`;
  }
  return defaultUrl;
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Testimonial).where(eq(Testimonial.id, id));
  } else if (act === 'update') {
    const original_id = formData.get('original_id') as string;
    const id = formData.get('id') as string;
    const name = formData.get('name') as string;
    const role = formData.get('role') as string;
    const content = formData.get('content') as string;

    const imgUrl = formData.get('avatar_url') as string || (formData.get('existing_avatar') as string) || '';
    const imgFile = formData.get('avatar_file') as File | null;
    const avatar = await processFile(imgFile, imgUrl);

    try {
      await db.update(Testimonial).set({ id, name, role, avatar, content }).where(eq(Testimonial.id, original_id));
    } catch (e) {
      console.error(e);
    }
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const name = formData.get('name') as string;
    const role = formData.get('role') as string;
    const content = formData.get('content') as string;

    const imgUrl = formData.get('avatar_url') as string || '';
    const imgFile = formData.get('avatar_file') as File | null;
    const avatar = await processFile(imgFile, imgUrl);

    try {
      await db.insert(Testimonial).values({ id, name, role, avatar, content });
    } catch (e) {
      console.error(e);
    }
  }
}

const testimonials = await db.select().from(Testimonial);
---

<DashboardLayout title="Manajemen Testimoni">
  <div class="dashboard-action-bar" style="margin-bottom: 2rem;">
    <!-- Tambah Testimonial Button -->
    <div class="glass-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-radius: 16px;">
      <div>
        <h4 style="margin: 0 0 0.5rem 0; font-weight: 600;">✨ Tambah Testimoni Klien</h4>
        <p class="text-muted" style="margin: 0; font-size: 0.9rem;">Masukan tanggapan dan review positif dari klien Anda.</p>
      </div>
      <button onclick="document.getElementById('add_modal').showModal()" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; font-weight: 600;">
        ➕ Tambah Testimoni
      </button>
    </div>

    <!-- Add Testimonial Modal -->
    <dialog id="add_modal" class="premium-modal" style="max-width: 800px; width: 90%;">
      <div class="modal-header">
        <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; background: linear-gradient(135deg, #fff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Testimoni Baru</h3>
        <button type="button" class="close-btn" onclick="document.getElementById('add_modal').close()">&times;</button>
      </div>
      
      <div class="modal-body">
        <form method="POST" enctype="multipart/form-data">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">ID Unik (contoh: pt-abcd)</label>
              <input type="text" name="id" class="premium-input" placeholder="contoh: budi-corp" required />
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Nama Klien</label>
              <input type="text" name="name" class="premium-input" placeholder="Contoh: Budi Santoso" required />
            </div>
            
            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Jabatan & Perusahaan</label>
              <input type="text" name="role" class="premium-input" placeholder="CEO Budi Corp" required />
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Foto Avatar (URL/Upload)</label>
              <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                <input type="url" name="avatar_url" class="premium-input" placeholder="URL Foto..." />
                <div style="background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.15); padding: 0.6rem; border-radius: 8px;">
                  <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.3rem;">Atau Unggah Dari Komputer:</span>
                  <input type="file" name="avatar_file" accept="image/*" style="font-size: 0.85rem; color: #fff; width: 100%;" />
                </div>
              </div>
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Ulasan / Testimoni</label>
              <textarea name="content" class="premium-input" rows="8" required></textarea>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn-cancel" onclick="document.getElementById('add_modal').close()">Batal</button>
            <button type="submit" class="btn-save">Simpan Testimoni</button>
          </div>
        </form>
      </div>
    </dialog>
  </div>

  <div>
    <h3 style="margin-bottom: 1.5rem; font-size: 1.2rem; font-weight: 600;">Data Testimoni Klien</h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
      {testimonials.map(t => (
        <div class="data-card glass-card" style="padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease;">
          <div>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
              <img src={t.avatar} alt={t.name} style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.1); box-shadow: 0 4px 10px rgba(0,0,0,0.3);" />
              <div>
                <h4 style="font-size: 1.1rem; font-weight: 600; color: #fff; margin-bottom: 0.2rem;">{t.name}</h4>
                <div class="text-muted" style="font-size: 0.85rem;">{t.role}</div>
              </div>
            </div>
            
            <div style="position: relative; padding: 1rem; background: rgba(0,0,0,0.2); border-radius: 12px; margin-bottom: 1.5rem;">
              <span style="position: absolute; top: -10px; left: 10px; font-size: 2rem; color: rgba(129, 140, 248, 0.4); font-family: serif; line-height: 1;">"</span>
              <p style="color: rgba(255,255,255,0.9); font-size: 0.95rem; font-style: italic; line-height: 1.6; position: relative; z-index: 1;">
                {t.content.length > 150 ? t.content.substring(0, 150) + '...' : t.content}
              </p>
            </div>
          </div>
          
          <div style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.2rem; display: flex; gap: 0.5rem; align-items: center;">
            <span style="font-family: monospace; font-size: 0.75rem; color: var(--text-muted); opacity: 0.5; margin-right: auto;">ID: {t.id}</span>
            <button type="button" onclick={`document.getElementById('edit_modal_${t.id}').showModal()`} class="action-btn" style="border-radius: 8px; padding: 0.4rem 1rem; background: rgba(99,102,241,0.1); color: #818cf8; border: 1px solid rgba(99,102,241,0.2);">✏️ Edit</button>
            <form method="POST" style="margin:0;" onsubmit="return confirm('Hapus permanen testimoni klien ini?');">
              <input type="hidden" name="action" value="delete"/>
              <input type="hidden" name="id" value={t.id}/>
              <button class="action-btn danger" style="border-radius: 8px; padding: 0.4rem 1rem;">Hapus</button>
            </form>

            <dialog id={`edit_modal_${t.id}`} class="premium-modal" style="max-width: 800px; width: 90%;">
              <div class="modal-header">
                <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; background: linear-gradient(135deg, #fff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Ubah Testimoni</h3>
                <button type="button" class="close-btn" onclick={`document.getElementById('edit_modal_${t.id}').close()`}>&times;</button>
              </div>
              
              <div class="modal-body">
                <form method="POST" enctype="multipart/form-data">
                  <input type="hidden" name="action" value="update"/>
                  <input type="hidden" name="original_id" value={t.id}/>
                  <input type="hidden" name="existing_avatar" value={t.avatar || ''}/>
                  
                  <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <div class="form-group" style="margin: 0;">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Kode ID</label>
                      <input type="text" name="id" class="premium-input" value={t.id} required />
                    </div>

                    <div class="form-group" style="margin: 0;">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Nama Klien</label>
                      <input type="text" name="name" class="premium-input" value={t.name} required />
                    </div>
                    
                    <div class="form-group" style="margin: 0;">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Jabatan & Perusahaan</label>
                      <input type="text" name="role" class="premium-input" value={t.role} required />
                    </div>

                    <div class="form-group" style="margin: 0;">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Foto Avatar (URL/Upload)</label>
                      <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                        <input type="url" name="avatar_url" class="premium-input" placeholder="URL Baru..." />
                        <div style="background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.15); padding: 0.6rem; border-radius: 8px;">
                          <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.3rem;">Atau Unggah Dari Komputer (Abaikan jika tetap):</span>
                          <input type="file" name="avatar_file" accept="image/*" style="font-size: 0.85rem; color: #fff; width: 100%;" />
                        </div>
                      </div>
                    </div>

                    <div class="form-group" style="margin: 0;">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Ulasan / Testimoni</label>
                      <textarea name="content" class="premium-input" rows="8" required>{t.content}</textarea>
                    </div>
                  </div>

                  <div class="modal-footer">
                    <button type="button" class="btn-cancel" onclick={`document.getElementById('edit_modal_${t.id}').close()`}>Batal</button>
                    <button type="submit" class="btn-save">Simpan Perubahan</button>
                  </div>
                </form>
              </div>
            </dialog>
          </div>
        </div>
      ))}
    </div>

    {testimonials.length === 0 && (
      <div class="glass-card" style="text-align:center; color: var(--text-muted); padding: 4rem 2rem; border-style: dashed;">
        <span style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 1rem;">💬</span>
        Belum ada entri testimoni. Silakan tambahkan testimoni klien pertama Anda.
      </div>
    )}
  </div>
</DashboardLayout>


