---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Message, desc, eq } from 'astro:db';

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const id = formData.get("id") as string;
  
  if (id) {
    await db.delete(Message).where(eq(Message.id, id));
  }
}

const messages = await db.select().from(Message).orderBy(desc(Message.created_at));
---

<DashboardLayout title="Kotak Masuk (Leads/Prospek)">
  <div class="glass-card" style="margin-bottom: 2rem;">
    <h3 class="title-md" style="margin-bottom: 1rem;">Daftar Pesan Masuk</h3>
    <p class="text-muted">Semua kueri dan prospek bisnis dari halaman formulir kontak Anda masuk dan diurutkan di sini secara langsung dari sistem pusat.</p>
  </div>

  <div class="messages-container" style="display: flex; flex-direction: column; gap: 1.5rem;">
    {messages.length === 0 ? (
      <div class="glass-card text-center text-muted" style="padding: 4rem; text-align: center;">
         Belum ada pesan / request konsultasi sejauh ini.
      </div>
    ) : messages.map((m) => (
      <div class="glass-card" style="display: flex; flex-direction: column; gap: 1rem; position: relative;">
        
        <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1rem;">
          <div>
            <h4 style="font-size: 1.2rem; margin-bottom: 0.2rem; display: flex; align-items: center; gap: 0.5rem;">
              👤 {m.name} 
              <span style="font-size: 0.8rem; background: rgba(56, 189, 248, 0.2); color: #38bdf8; padding: 0.2rem 0.5rem; border-radius: 4px;">{m.service}</span>
            </h4>
            <a href={`mailto:${m.email}`} class="text-muted" style="font-size: 0.9rem; text-decoration: none;">📧 {m.email}</a>
          </div>
          
          <div style="text-align: right;">
            <span class="text-muted" style="font-size: 0.8rem;">Dikirim: {m.created_at.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
          </div>
        </div>
        
        <div class="message-content" style="padding: 1rem; background: rgba(0,0,0,0.3); border-radius: 8px; font-size: 1rem; line-height: 1.6; white-space: pre-wrap;">{m.content}</div>
        
        <form method="POST" style="text-align: right; margin-top: 0.5rem;" onsubmit="return confirm('Pesan dihapus permanen. Lanjutkan?');">
          <input type="hidden" name="id" value={m.id} />
          <button type="submit" style="background: rgba(239, 68, 68, 0.2); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.4); padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer; transition: all 0.2s;">🗑️ Hapus Pesan</button>
        </form>
        
      </div>
    ))}
  </div>
</DashboardLayout>
