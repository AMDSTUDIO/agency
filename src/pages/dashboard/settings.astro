---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, GlobalSetting, eq } from 'astro:db';

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  
  // Update logic: since it's key-value, we loop over all entries in the form
  // and update or insert them. Or simply loop through what we care about.
  for (const [key, value] of formData.entries()) {
    if (typeof value === 'string' && key !== 'action') {
      try {
        const exist = await db.select().from(GlobalSetting).where(eq(GlobalSetting.key, key));
        if (exist.length > 0) {
          await db.update(GlobalSetting).set({ value }).where(eq(GlobalSetting.key, key));
        } else {
          await db.insert(GlobalSetting).values({ key, value });
        }
      } catch(e) {
        console.error("Error saving setting:", key, e);
      }
    }
  }
}

// Fetch all settings
const rawSettings = await db.select().from(GlobalSetting);
const settings = Object.fromEntries(rawSettings.map(s => [s.key, s.value]));

const hero_title_default = "Membangun Masa Depan <br/>\n<span class=\"text-gradient\">Digital & Bisnis</span>";
const services_title_default = "Layanan <span class=\"text-gradient\">Kami</span>";
---

<DashboardLayout title="Pengaturan Global Situs">
  <div style="max-width: 1000px; margin: 0 auto;">
    
    <div style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; letter-spacing: -0.02em;">Sistem Kendali Global</h2>
      <p class="text-muted" style="font-size: 1.1rem; line-height: 1.6;">Atur identitas merek, meta-data mesin pencari, serta seluruh terminologi pada halaman terdepan (Frontpage) dari satu panel komando pusat.</p>
    </div>
    
    <form method="POST">
      <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
        
        <!-- Identitas Dasar & Footer -->
        <div class="glass-card" style="padding: 2.5rem; border-top: 4px solid var(--primary);">
          <h3 style="margin-bottom: 1.5rem; font-size: 1.25rem; font-weight: 600; display:flex; align-items:center; gap:0.5rem;">
            <span>🏢</span> Identitas Korporat & Kontak
          </h3>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
            <div class="form-group">
              <label class="form-label">Nama Logo / Brand Utama</label>
              <input type="text" name="site_logo" class="form-input" value={settings.site_logo || "Creative Studio"} />
            </div>
            <div class="form-group">
               <label class="form-label">Teks Slogan (Footer)</label>
               <input type="text" name="footer_desc" class="form-input" value={settings.footer_desc || "Partner digital..."} />
            </div>
            <div class="form-group">
              <label class="form-label">Alamat Surat Elektronik</label>
              <input type="email" name="footer_email" class="form-input" value={settings.footer_email || ""} />
            </div>
            <div class="form-group">
              <label class="form-label">Nomor WhatsApp Resmi</label>
              <input type="text" name="whatsapp_number" class="form-input" value={settings.whatsapp_number || "085163219924"} />
            </div>
            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Alamat Kantor Geografis</label>
              <input type="text" name="footer_address" class="form-input" value={settings.footer_address || ""} />
            </div>
          </div>
        </div>

        <!-- SEO -->
        <div class="glass-card" style="padding: 2.5rem; border-top: 4px solid #10b981;">
          <h3 style="margin-bottom: 1.5rem; font-size: 1.25rem; font-weight: 600; display:flex; align-items:center; gap:0.5rem;">
            <span>🔍</span> Optimasi Mesin Pencari (SEO)
          </h3>
          <div style="display:flex; flex-direction:column; gap:1.5rem;">
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label">Judul Tab Browser Utama <i>(Meta Title)</i></label>
              <input type="text" name="seo_brand_title" class="form-input" value={settings.seo_brand_title || "Creative Agency - Jasa Pembuatan Website & Digital Marketing"} style="font-size: 1.1rem; color: #60a5fa;" />
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label">Deskripsi Situs <i>(Meta Description)</i></label>
              <textarea name="seo_meta_desc" class="form-input" rows="2" style="color: #a7f3d0;">{settings.seo_meta_desc || "Konsultan rancang bangun piranti lunak, ekosistem website..."}</textarea>
              <p style="font-size: 0.8rem; color: rgba(255,255,255,0.4); margin-top:0.4rem;">Direkomendasikan antara 120-160 karakter untuk indeks terbaik di Google.</p>
            </div>
          </div>
        </div>

        <!-- Etalase Pintu Depan -->
        <div class="glass-card" style="padding: 2.5rem; border-top: 4px solid #8b5cf6;">
          <h3 style="margin-bottom: 1.5rem; font-size: 1.25rem; font-weight: 600; display:flex; align-items:center; gap:0.5rem;">
            <span>🌠</span> Layar Penuh (Hero Section)
          </h3>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Efek Lencana Teratas (Badge)</label>
              <input type="text" name="hero_badge" class="form-input" value={settings.hero_badge || "🔥 DIGITAL & BISNIS"} style="width: 50%;" />
            </div>
            
            <div class="form-group" style="grid-column: 1 / -1;">
               <label class="form-label">Judul Raksasa (Headline)</label>
               <textarea name="hero_title" class="form-input" rows="2" style="font-size: 1.1rem; font-family: monospace;">{settings.hero_title || hero_title_default}</textarea>
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Dekripsi Pendukung Headline</label>
              <textarea name="hero_desc" class="form-input" rows="2">{settings.hero_desc || ""}</textarea>
            </div>
            
            <div class="form-group">
              <label class="form-label">Teks CTA Primer (Tombol Ungu)</label>
              <input type="text" name="hero_btn_primary" class="form-input" value={settings.hero_btn_primary || "Mulai Proyek Anda"} />
            </div>
            <div class="form-group">
              <label class="form-label">Teks CTA Sekunder (Tombol Transparan)</label>
              <input type="text" name="hero_btn_secondary" class="form-input" value={settings.hero_btn_secondary || "Lihat Layanan"} />
            </div>
          </div>
        </div>

        <!-- Takarir Bagian -->
        <div class="glass-card" style="padding: 2.5rem; border-top: 4px solid #ec4899;">
          <h3 style="margin-bottom: 1.5rem; font-size: 1.25rem; font-weight: 600; display:flex; align-items:center; gap:0.5rem;">
            <span>🏷️</span> Penamaan & Label Seksi Halaman
          </h3>
          
          <div style="display:grid; grid-template-columns: 1fr 1.5fr; gap:1.5rem; align-items: start;">
            <!-- Row 1 -->
            <div class="form-group" style="margin:0;">
              <label class="form-label">Blok "Layanan"</label>
              <input type="text" name="services_title" class="form-input" value={settings.services_title || services_title_default} />
            </div>
            <div class="form-group" style="margin:0;">
              <label class="form-label">Kalimat Penjelas Layanan</label>
              <input type="text" name="services_desc" class="form-input" value={settings.services_desc || ""} />
            </div>

            <!-- Row 2 -->
            <div class="form-group" style="margin:0;">
              <label class="form-label">Blok "Portfolio"</label>
              <input type="text" name="portfolio_title" class="form-input" value={settings.portfolio_title || "Portfolio <span class=\"text-gradient\">Unggulan</span>"} />
            </div>
            <div class="form-group" style="margin:0;">
               <label class="form-label">Kalimat Penjelas Portfolio</label>
               <input type="text" name="portfolio_desc" class="form-input" value={settings.portfolio_desc || ""} />
            </div>

            <!-- Row 3 -->
            <div class="form-group" style="margin:0;">
               <label class="form-label">Blok "Testimoni"</label>
               <input type="text" name="testimonials_title" class="form-input" value={settings.testimonials_title || "Apa Kata <span class=\"text-gradient\">Klien Kami</span>"} />
            </div>
            <div class="form-group" style="margin:0;">
               <label class="form-label">Kalimat Penjelas Testimoni</label>
               <input type="text" name="testimonials_desc" class="form-input" value={settings.testimonials_desc || ""} />
            </div>

            <!-- Row 4 -->
            <div class="form-group" style="margin:0;">
               <label class="form-label">Blok "Artikel Blog"</label>
               <input type="text" name="blog_title" class="form-input" value={settings.blog_title || "Artikel & <span class=\"text-gradient\">Wawasan</span>"} />
            </div>
            <div class="form-group" style="margin:0;">
               <label class="form-label">Kalimat Penjelas Artikel Blog</label>
               <input type="text" name="blog_desc" class="form-input" value={settings.blog_desc || ""} />
            </div>
          </div>
        </div>
      </div>
      
      <!-- Save Action -->
      <div style="margin-top: 3rem; text-align: center; position: sticky; bottom: 2rem; z-index: 50;">
        <button type="submit" class="btn btn-primary" style="padding: 1.2rem 4rem; font-size: 1.15rem; font-weight: bold; border-radius: 99px; box-shadow: 0 10px 40px rgba(99, 102, 241, 0.5); border: 2px solid rgba(255,255,255,0.2); backdrop-filter: blur(10px);">
          💾 Publikasikan Pembaruan Konfigurasi
        </button>
      </div>
    </form>
  </div>
</DashboardLayout>
