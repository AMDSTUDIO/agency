---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Client, GlobalSetting, eq } from 'astro:db';
import fs from 'node:fs/promises';
import path from 'node:path';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'update_rule') {
    const rule = formData.get('rule') as string;
    const existingRule = await db.select().from(GlobalSetting).where(eq(GlobalSetting.key, "client_display_rule"));
    if (existingRule.length > 0) {
      // Drizzle/Astro DB uses update for existing rows
      await db.update(GlobalSetting).set({ value: rule }).where(eq(GlobalSetting.key, "client_display_rule"));
    } else {
      await db.insert(GlobalSetting).values({ key: "client_display_rule", value: rule });
    }
  } else if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Client).where(eq(Client.id, id));
  } else if (act === 'update') {
    const id = formData.get('id') as string;
    const name = formData.get('name') as string;
    const currentLogo = formData.get('current_logo') as string;
    const logoFile = formData.get('logo') as File;
    
    let logoUrl = currentLogo;

    if (logoFile && logoFile.size > 0) {
      const arrayBuffer = await logoFile.arrayBuffer();
      const buffer = Buffer.from(arrayBuffer);
      const randomSuffix = Math.floor(Math.random() * 10000).toString();
      const safeName = logoFile.name.replace(/[^a-zA-Z0-9.\-]/g, "");
      const fileName = `client_${Date.now()}_${randomSuffix}_${safeName}`;
      
      const dirPath = path.join(process.cwd(), 'public', 'clients');
      await fs.mkdir(dirPath, { recursive: true }).catch(() => {});
      
      await fs.writeFile(path.join(dirPath, fileName), buffer);
      logoUrl = `/clients/${fileName}`;
    }

    try {
      await db.update(Client).set({ name, logo: logoUrl }).where(eq(Client.id, id));
    } catch (e) {
      console.error(e);
    }
  } else if (act === 'create') {
    const name = formData.get('name') as string;
    const logoFile = formData.get('logo') as File;
    
    const id = 'client_' + Date.now().toString(36);
    let logoUrl = '';

    if (logoFile && logoFile.size > 0) {
      const arrayBuffer = await logoFile.arrayBuffer();
      const buffer = Buffer.from(arrayBuffer);
      const randomSuffix = Math.floor(Math.random() * 10000).toString();
      const safeName = logoFile.name.replace(/[^a-zA-Z0-9.\-]/g, "");
      const fileName = `client_${Date.now()}_${randomSuffix}_${safeName}`;
      
      const dirPath = path.join(process.cwd(), 'public', 'clients');
      await fs.mkdir(dirPath, { recursive: true }).catch(() => {});
      
      await fs.writeFile(path.join(dirPath, fileName), buffer);
      logoUrl = `/clients/${fileName}`;
    }

    try {
      await db.insert(Client).values({ id, name, logo: logoUrl });
    } catch (e) {
      console.error(e);
    }
  }
}

const clientsData = await db.select().from(Client);

const settingQuery = await db.select().from(GlobalSetting).where(eq(GlobalSetting.key, "client_display_rule"));
const currentRule = settingQuery.length > 0 ? settingQuery[0].value : "logo";
---

<DashboardLayout title="Manajemen Klien">
  <div class="dashboard-action-bar" style="margin-bottom: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
    <!-- Bagian Pengatur Tampilan Marquee -->
    <div class="glass-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-radius: 16px;">
      <div>
        <h4 style="margin: 0 0 0.5rem 0; font-weight: 600;">🌟 Opsi Tampilan Marquee Client</h4>
        <p class="text-muted" style="margin: 0; font-size: 0.9rem;">Pilih komponen mana yang terlihat berjejeran di halaman depan.</p>
      </div>
      <form method="POST" style="margin: 0; display: flex; gap: 1rem; align-items: center;">
        <input type="hidden" name="action" value="update_rule"/>
        <select name="rule" class="form-input" style="width: auto; padding: 0.6rem 2rem 0.6rem 1rem;" onchange="this.form.submit()">
          <option value="logo" selected={currentRule === "logo"}>Hanya Logo Instansi</option>
          <option value="name" selected={currentRule === "name"}>Hanya Nama Teks</option>
          <option value="both" selected={currentRule === "both"}>Logo Beserta Nama</option>
        </select>
      </form>
    </div>

    <!-- Tambah Klien Form -->
    <details class="glass-card add-new-details">
      <summary class="add-new-summary">
        <span style="display: flex; align-items: center; gap: 0.5rem;"><span style="font-size: 1.2rem;">✨</span> Tambah Klien & Logo</span>
        <span class="indicator text-muted">Buka formulir &darr;</span>
      </summary>
      
      <div class="add-new-content">
        <form method="POST" enctype="multipart/form-data">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
            <div class="form-group">
              <label class="form-label">Nama Instansi / Klien</label>
              <input type="text" name="name" class="form-input" required placeholder="Contoh: Masjid Raya..." />
            </div>

            <div class="form-group">
              <label class="form-label">Unggah Gambar Logo (PNG/JPG/SVG/WEBP)</label>
              <input type="file" name="logo" class="form-input" accept="image/*" required style="padding: 0.5rem; background: rgba(0,0,0,0.2)" />
            </div>
          </div>

          <div style="margin-top: 1.5rem; text-align: right;">
            <button type="submit" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">🚀 Simpan Klien</button>
          </div>
        </form>
      </div>
    </details>
  </div>

  <div>
    <h3 style="margin-bottom: 1.5rem; font-size: 1.2rem; font-weight: 600;">Direktori Klien Aktif</h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem;">
      {clientsData.map(c => (
        <div class="data-card glass-card" style="display: flex; flex-direction: column; overflow: hidden; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease;">
          <div style="position: relative; height: 140px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.03); padding: 1.5rem;">
            <img src={c.logo} alt={c.name} style="max-width: 100%; max-height: 100%; object-fit: contain; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));" />
          </div>
          
          <div style="padding: 1.25rem; display: flex; flex-direction: column; flex: 1; justify-content: space-between;">
            <div style="margin-bottom: 1rem; text-align: center;">
              <h4 style="font-size: 1.05rem; font-weight: 600; color: #fff; line-height: 1.3;">{c.name}</h4>
              <span style="font-size: 0.75rem; color: var(--text-muted); border-radius: 4px; padding: 0.2rem 0.5rem; background: rgba(0,0,0,0.2); display: inline-block; margin-top: 0.5rem;">ID: {c.id}</span>
            </div>
            
            <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem; display: flex; gap: 0.5rem; flex-direction: column;">
              <button type="button" onclick={`document.getElementById('edit_modal_${c.id}').showModal()`} class="action-btn" style="width: 100%; border-radius: 8px; padding: 0.6rem; background: rgba(99,102,241,0.1); color: #818cf8; border: 1px solid rgba(99,102,241,0.2);">✏️ Edit</button>
              <form method="POST" style="margin:0;" onsubmit="return confirm('Apakah Anda yakin ingin menghapus klien ini?');">
                <input type="hidden" name="action" value="delete"/>
                <input type="hidden" name="id" value={c.id}/>
                <button class="action-btn danger" style="width: 100%; border-radius: 8px; padding: 0.6rem;">🗑️ Hapus</button>
              </form>

              <dialog id={`edit_modal_${c.id}`} class="premium-modal">
                <div class="modal-header">
                  <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; background: linear-gradient(135deg, #fff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Ubah Profil Klien</h3>
                  <button type="button" class="close-btn" onclick={`document.getElementById('edit_modal_${c.id}').close()`}>&times;</button>
                </div>
                
                <div class="modal-body">
                  <div style="display: flex; justify-content: center; margin-bottom: 2rem;">
                    <div style="width: 80px; height: 80px; padding: 0.5rem; background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                      <img src={c.logo} alt="Current Logo" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                    </div>
                  </div>

                  <form method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="action" value="update"/>
                    <input type="hidden" name="id" value={c.id}/>
                    <input type="hidden" name="current_logo" value={c.logo}/>
                    
                    <div class="form-group">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Nama Instansi</label>
                      <input type="text" name="name" class="premium-input" value={c.name} required />
                    </div>
                    
                    <div class="form-group" style="margin-top: 1.5rem;">
                      <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Unggah Logo Baru</label>
                      <label class="file-upload-zone">
                        <input type="file" name="logo" accept="image/*" />
                        <span class="upload-text">Klik untuk menelusuri atau seret gambar ke area ini</span>
                      </label>
                      <p class="text-muted" style="font-size: 0.75rem; margin-top: 0.5rem;">Abaikan jika tidak ingin mengganti logo saat ini.</p>
                    </div>
                    
                    <div class="modal-footer">
                      <button type="button" class="btn-cancel" onclick={`document.getElementById('edit_modal_${c.id}').close()`}>Batal</button>
                      <button type="submit" class="btn-save">Simpan Perubahan</button>
                    </div>
                  </form>
                </div>
              </dialog>
            </div>
          </div>
        </div>
      ))}
    </div>

    {clientsData.length === 0 && (
      <div class="glass-card" style="text-align:center; color: var(--text-muted); padding: 4rem 2rem; border-style: dashed;">
        <span style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 1rem;">🏢</span>
        Belum ada entri logo klien. Silakan tambahkan klien pertama Anda.
      </div>
    )}
  </div>
</DashboardLayout>

<style is:global>
  .add-new-details {
    padding: 0;
    transition: all 0.3s ease;
  }
  .add-new-details[open] {
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .add-new-summary {
    list-style: none;
    padding: 1.5rem 2rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    user-select: none;
  }
  .add-new-summary::-webkit-details-marker {
    display: none;
  }
  .add-new-content {
    padding: 0 2rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: 0.5rem;
    padding-top: 1.5rem;
    animation: slideDown 0.3s ease-out forwards;
  }
  
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Premium Dialog Modal Styles */
  .premium-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.95);
    margin: 0;
    padding: 0;
    width: 90%;
    max-width: 480px;
    background: rgba(15, 20, 30, 0.85);
    backdrop-filter: blur(20px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    color: white;
    box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* When dialog is open */
  .premium-modal[open] {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
    z-index: 1000;
  }

  .premium-modal::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    animation: fade-in 0.3s ease-out forwards;
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .modal-header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .close-btn {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s;
  }
  .close-btn:hover {
    color: #fff;
  }

  .modal-body {
    padding: 2rem;
  }

  .premium-input {
    width: 100%;
    padding: 1rem 1.2rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(0, 0, 0, 0.3);
    color: #fff;
    font-size: 1rem;
    outline: none;
    transition: all 0.3s;
  }
  .premium-input:focus {
    border-color: rgba(129, 140, 248, 0.6);
    background: rgba(0, 0, 0, 0.5);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
  }

  .file-upload-zone {
    display: block;
    position: relative;
    padding: 1.5rem;
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.01);
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
  }
  .file-upload-zone:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(129, 140, 248, 0.5);
  }
  .file-upload-zone input[type="file"] {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    opacity: 0;
    cursor: pointer;
  }
  .upload-text {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .modal-footer {
    margin-top: 2.5rem;
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
  }

  .btn-cancel {
    padding: 0.8rem 1.5rem;
    border-radius: 99px;
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-cancel:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
  }

  .btn-save {
    padding: 0.8rem 2rem;
    border-radius: 99px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    border: none;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 10px 20px -5px rgba(99, 102, 241, 0.4);
    transition: all 0.3s;
  }
  .btn-save:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 25px -5px rgba(99, 102, 241, 0.6);
  }
</style>
