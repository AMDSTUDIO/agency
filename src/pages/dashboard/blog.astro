---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Blog, eq } from 'astro:db';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Blog).where(eq(Blog.id, id));
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const category = formData.get('category') as string;
    const author = formData.get('author') as string;
    const img = formData.get('img') as string;
    const excerpt = formData.get('excerpt') as string;
    const content = formData.get('content') as string;
    
    // Astro DB requires a Date object for date columns
    const date = new Date();

    try {
      await db.insert(Blog).values({ id, title, category, date, author, img, excerpt, content });
    } catch (e) {
      console.error(e);
    }
  }
}

const blogs = await db.select().from(Blog);
---

<DashboardLayout title="Manajemen Artikel & Blog">
  <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem;">
    
    <div class="glass-card">
      <h3 class="title-md" style="margin-bottom: 1.5rem; font-size: 1.2rem;">Tambah Artikel Baru</h3>
      
      <form method="POST">
        <input type="hidden" name="action" value="create"/>
        
        <div class="form-group">
          <label class="form-label">ID / Slug Unik (contoh: belajar-seo)</label>
          <input type="text" name="id" class="form-input" required />
        </div>

        <div class="form-group">
          <label class="form-label">Judul Artikel</label>
          <input type="text" name="title" class="form-input" required />
        </div>

        <div style="display:flex; gap:1rem;">
          <div class="form-group" style="flex:1;">
            <label class="form-label">Kategori</label>
            <input type="text" name="category" class="form-input" required />
          </div>
          <div class="form-group" style="flex:1;">
            <label class="form-label">Penulis</label>
            <input type="text" name="author" class="form-input" value="Admin" required />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">URL Gambar Cover</label>
          <input type="url" name="img" class="form-input" required />
        </div>

        <div class="form-group">
          <label class="form-label">Ringkasan (Excerpt)</label>
          <textarea name="excerpt" class="form-input" rows="2" required></textarea>
        </div>

        <div class="form-group">
          <label class="form-label">Konten Utama (HTML/Teks)</label>
          <textarea name="content" class="form-input" rows="8" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%;">Terbitkan Artikel</button>
      </form>
    </div>

    <div class="glass-card table-container">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Info Artikel</th>
            <th>Kategori</th>
            <th>Tanggal</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          {blogs.map(b => (
            <tr>
              <td><strong>{b.title}</strong><br/><small class="text-muted">Oleh: {b.author}</small></td>
              <td><span style="background:rgba(255,255,255,0.1); padding:0.3rem 0.6rem; border-radius:5px; font-size:0.8rem;">{b.category}</span></td>
              <td><small>{b.date.toLocaleDateString()}</small></td>
              <td>
                <form method="POST" style="display:inline;" onsubmit="return confirm('Hapus artikel ini?');">
                  <input type="hidden" name="action" value="delete"/>
                  <input type="hidden" name="id" value={b.id}/>
                  <button class="action-btn danger">Hapus</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>
