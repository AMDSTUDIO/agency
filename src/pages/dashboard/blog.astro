---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Blog, eq } from 'astro:db';
import fs from 'node:fs';
import path from 'node:path';

async function processFile(file: File | null, defaultUrl: string) {
  if (file && file.size > 0 && file.name) {
    const dir = path.join(process.cwd(), 'public', 'uploads');
    if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
    const ext = file.name.split('.').pop() || 'png';
    const name = `${Date.now()}-${Math.round(Math.random()*1000)}.${ext}`;
    const buffer = Buffer.from(await file.arrayBuffer());
    fs.writeFileSync(path.join(dir, name), buffer);
    return `/uploads/${name}`;
  }
  return defaultUrl;
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Blog).where(eq(Blog.id, id));
  } else if (act === 'update') {
    const original_id = formData.get('original_id') as string;
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const category = formData.get('category') as string;
    const author = formData.get('author') as string;
    const excerpt = formData.get('excerpt') as string;
    const content = formData.get('content') as string;

    const imgUrl = formData.get('img_url') as string || (formData.get('existing_img') as string) || '';
    const imgFile = formData.get('img_file') as File | null;
    const img = await processFile(imgFile, imgUrl);

    try {
      await db.update(Blog).set({ id, title, category, author, img, excerpt, content }).where(eq(Blog.id, original_id));
    } catch (e) {
      console.error(e);
    }
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const category = formData.get('category') as string;
    const author = formData.get('author') as string;
    const excerpt = formData.get('excerpt') as string;
    const content = formData.get('content') as string;
    
    const imgUrl = formData.get('img_url') as string || '';
    const imgFile = formData.get('img_file') as File | null;
    const img = await processFile(imgFile, imgUrl);
    
    // Astro DB requires a Date object for date columns
    const date = new Date();

    try {
      await db.insert(Blog).values({ id, title, category, date, author, img, excerpt, content });
    } catch (e) {
      console.error(e);
    }
  }
}

const blogs = await db.select().from(Blog);
---

<DashboardLayout title="Manajemen Artikel & Blog">
  <div class="dashboard-action-bar" style="margin-bottom: 2rem;">
    <!-- Tambah Blog Button -->
    <div class="glass-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-radius: 16px;">
      <div>
        <h4 style="margin: 0 0 0.5rem 0; font-weight: 600;">✨ Buat Artikel Baru</h4>
        <p class="text-muted" style="margin: 0; font-size: 0.9rem;">Bagikan cerita dan berita terbaru ke pembaca Anda.</p>
      </div>
      <button onclick="document.getElementById('add_modal').showModal()" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; font-weight: 600;">
        ➕ Tulis Artikel
      </button>
    </div>

    <!-- Add Blog Modal -->
    <dialog id="add_modal" class="premium-modal" style="max-width: 800px; width: 90%;">
      <div class="modal-header">
        <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; background: linear-gradient(135deg, #fff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Editor Artikel</h3>
        <button type="button" class="close-btn" onclick="document.getElementById('add_modal').close()">&times;</button>
      </div>
      
      <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
        <form method="POST" enctype="multipart/form-data">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Slug (URL Unik)</label>
              <input type="text" name="id" class="premium-input" placeholder="contoh: belajar-seo-2024" required />
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Judul Artikel Utama</label>
              <input type="text" name="title" class="premium-input" placeholder="Contoh: 10 Cara SEO Akurat" required />
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
              <div class="form-group" style="margin: 0;">
                <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Topik / Kategori</label>
                <input type="text" name="category" class="premium-input" required />
              </div>
              <div class="form-group" style="margin: 0;">
                <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Nama Penulis</label>
                <input type="text" name="author" class="premium-input" value="Admin" required />
              </div>
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Gambar Cover (URL/Upload)</label>
              <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                <input type="url" name="img_url" class="premium-input" placeholder="URL Gambar..." />
                <div style="background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.15); padding: 0.6rem; border-radius: 8px;">
                  <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.3rem;">Atau Unggah Dari Komputer:</span>
                  <input type="file" name="img_file" accept="image/*" style="font-size: 0.85rem; color: #fff; width: 100%;" />
                </div>
              </div>
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Ringkasan (Excerpt)</label>
              <textarea name="excerpt" class="premium-input" rows="2" placeholder="1-2 kalimat pemancing pembaca..." required></textarea>
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Konten Tulisan (HTML Mendukung)</label>
              <textarea name="content" class="premium-input" rows="5" placeholder="Tuliskan isi artikel Anda..." required></textarea>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn-cancel" onclick="document.getElementById('add_modal').close()">Batal</button>
            <button type="submit" class="btn-save">Terbitkan Artikel</button>
          </div>
        </form>
      </div>
    </dialog>
  </div>

  <div>
    <h3 style="margin-bottom: 1.5rem; font-size: 1.2rem; font-weight: 600;">Arsip Jurnal & Artikel</h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
      {blogs.map(b => (
        <div class="data-card glass-card" style="display: flex; flex-direction: column; overflow: hidden; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease;">
          <div style="position: relative; padding-top: 50%;">
            <img src={b.img} alt={b.title} style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" />
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to top, rgba(9,10,15,1) 0%, rgba(9,10,15,0) 100%);"></div>
            <span style="position: absolute; top: 1rem; left: 1rem; background: rgba(99, 102, 241, 0.9); backdrop-filter: blur(5px); padding: 0.3rem 0.8rem; border-radius: 99px; color: #fff; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; box-shadow: 0 4px 10px rgba(0,0,0,0.3);">{b.category}</span>
          </div>
          
          <div style="padding: 1.5rem; display: flex; flex-direction: column; flex: 1; justify-content: space-between; margin-top: -3rem; position: relative; z-index: 2;">
            <div style="margin-bottom: 1.5rem;">
              <h4 style="font-size: 1.2rem; font-weight: 700; color: #fff; line-height: 1.4; margin-bottom: 0.5rem; text-shadow: 0 2px 4px rgba(0,0,0,0.5);">{b.title}</h4>
              <p class="text-muted" style="font-size: 0.9rem; line-height: 1.5;">{b.excerpt}</p>
            </div>
            
            <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.2rem; display: flex; gap: 0.5rem; align-items: center;">
              <div style="font-size: 0.8rem; color: var(--text-muted); margin-right: auto;">
                <span style="display: block; color: rgba(255,255,255,0.8); font-weight: 600;">{b.author}</span>
                {b.date.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' })}
              </div>
              <button type="button" onclick={`document.getElementById('edit_modal_${b.id}').showModal()`} class="action-btn" style="border-radius: 8px; padding: 0.4rem 1rem; background: rgba(99,102,241,0.1); color: #818cf8; border: 1px solid rgba(99,102,241,0.2);">✏️ Edit</button>
              <form method="POST" style="margin:0;" onsubmit="return confirm('Hapus permanen artikel jurnal ini?');">
                <input type="hidden" name="action" value="delete"/>
                <input type="hidden" name="id" value={b.id}/>
                <button class="action-btn danger" style="border-radius: 8px; padding: 0.4rem 1rem;">Hapus</button>
              </form>

              <dialog id={`edit_modal_${b.id}`} class="premium-modal" style="max-width: 800px; width: 90%;">
                <div class="modal-header">
                  <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; background: linear-gradient(135deg, #fff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Ubah Artikel</h3>
                  <button type="button" class="close-btn" onclick={`document.getElementById('edit_modal_${b.id}').close()`}>&times;</button>
                </div>
                
                <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
                  <form method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="action" value="update"/>
                    <input type="hidden" name="original_id" value={b.id}/>
                    <input type="hidden" name="existing_img" value={b.img || ''}/>
                    
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Slug (URL Unik)</label>
                        <input type="text" name="id" class="premium-input" value={b.id} required />
                      </div>

                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Judul Artikel Utama</label>
                        <input type="text" name="title" class="premium-input" value={b.title} required />
                      </div>
                      
                      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="form-group" style="margin: 0;">
                          <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Topik / Kategori</label>
                          <input type="text" name="category" class="premium-input" value={b.category} required />
                        </div>
                        <div class="form-group" style="margin: 0;">
                          <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Nama Penulis</label>
                          <input type="text" name="author" class="premium-input" value={b.author} required />
                        </div>
                      </div>

                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase;">Gambar Cover (URL/Upload)</label>
                        <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                          <input type="url" name="img_url" class="premium-input" placeholder="URL Baru..." />
                          <div style="background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.15); padding: 0.6rem; border-radius: 8px;">
                            <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.3rem;">Atau Unggah Dari Komputer (Abaikan jika tetap):</span>
                            <input type="file" name="img_file" accept="image/*" style="font-size: 0.85rem; color: #fff; width: 100%;" />
                          </div>
                        </div>
                      </div>

                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Ringkasan (Excerpt)</label>
                        <textarea name="excerpt" class="premium-input" rows="2" required>{b.excerpt}</textarea>
                      </div>

                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Konten Tulisan (HTML Mendukung)</label>
                        <textarea name="content" class="premium-input" rows="5" required>{b.content}</textarea>
                      </div>
                    </div>

                    <div class="modal-footer">
                      <button type="button" class="btn-cancel" onclick={`document.getElementById('edit_modal_${b.id}').close()`}>Batal</button>
                      <button type="submit" class="btn-save">Simpan Perubahan</button>
                    </div>
                  </form>
                </div>
              </dialog>
            </div>
          </div>
        </div>
      ))}
    </div>

    {blogs.length === 0 && (
      <div class="glass-card" style="text-align:center; color: var(--text-muted); padding: 4rem 2rem; border-style: dashed;">
        <span style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 1rem;">📝</span>
        Belum ada artikel yang diterbitkan. Silakan tulis artikel pertama Anda.
      </div>
    )}
  </div>
</DashboardLayout>


