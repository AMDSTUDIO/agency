---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Blog, eq } from 'astro:db';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Blog).where(eq(Blog.id, id));
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const category = formData.get('category') as string;
    const author = formData.get('author') as string;
    const img = formData.get('img') as string;
    const excerpt = formData.get('excerpt') as string;
    const content = formData.get('content') as string;
    
    // Astro DB requires a Date object for date columns
    const date = new Date();

    try {
      await db.insert(Blog).values({ id, title, category, date, author, img, excerpt, content });
    } catch (e) {
      console.error(e);
    }
  }
}

const blogs = await db.select().from(Blog);
---

<DashboardLayout title="Manajemen Artikel & Blog">
  <div class="dashboard-action-bar" style="margin-bottom: 2rem;">
    <details class="glass-card add-new-details">
      <summary class="add-new-summary">
        <span style="display: flex; align-items: center; gap: 0.5rem;"><span style="font-size: 1.2rem;">✨</span> Buat Artikel Baru</span>
        <span class="indicator text-muted">Buka editor &darr;</span>
      </summary>
      
      <div class="add-new-content">
        <form method="POST">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
            <div class="form-group">
              <label class="form-label">ID / Slug Unik (contoh: belajar-seo-2024)</label>
              <input type="text" name="id" class="form-input" required />
            </div>

            <div class="form-group">
              <label class="form-label">Judul Artikel Lengkap</label>
              <input type="text" name="title" class="form-input" required />
            </div>

            <div style="display:flex; gap:1rem;">
              <div class="form-group" style="flex:1;">
                <label class="form-label">Topik Kategori</label>
                <input type="text" name="category" class="form-input" required />
              </div>
              <div class="form-group" style="flex:1;">
                <label class="form-label">Nama Penulis</label>
                <input type="text" name="author" class="form-input" value="Admin" required />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">URL Gambar Sampul Resolusi Tinggi</label>
              <input type="url" name="img" class="form-input" required />
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Ringkasan Pendek (Excerpt)</label>
              <textarea name="excerpt" class="form-input" rows="2" placeholder="Tuliskan 1-2 kalimat pemancing rasa penasaran pembaca..." required></textarea>
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Konten Utama (HTML/Teks Bebas)</label>
              <textarea name="content" class="form-input" rows="10" placeholder="Tulis artikel panjang di sini. Anda bisa memakai format tag HTML dasar seperti <p>, <br>, <strong>..." required></textarea>
            </div>
          </div>

          <div style="margin-top: 1.5rem; text-align: right;">
            <button type="submit" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">🚀 Terbitkan Artikel</button>
          </div>
        </form>
      </div>
    </details>
  </div>

  <div class="table-container glass-card" style="padding: 0;">
    <h3 style="padding: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); margin: 0; font-size: 1.2rem;">Arsip Publikasi</h3>
    <div style="overflow-x: auto;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Info Artikel</th>
            <th style="text-align:center;">Kategori</th>
            <th style="text-align:center;">Tanggal Terbit</th>
            <th style="text-align:right;">Aksi</th>
          </tr>
        </thead>
        <tbody>
          {blogs.map(b => (
            <tr>
              <td>
                <div style="font-weight: 600; color: #fff; font-size: 1.05rem;">{b.title}</div>
                <div class="text-muted" style="font-size: 0.85rem; margin-top: 0.3rem;">Oleh Penulis: {b.author}</div>
              </td>
              <td style="text-align:center;"><span style="background:rgba(99, 102, 241, 0.15); color: #818cf8; font-weight:600; padding:0.4rem 0.8rem; border-radius:8px; font-size:0.8rem; letter-spacing:0.05em; text-transform:uppercase;">{b.category}</span></td>
              <td style="text-align:center; color: var(--text-muted); font-size: 0.9rem;">{b.date.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</td>
              <td style="text-align:right;">
                <form method="POST" style="margin:0;" onsubmit="return confirm('Hapus permanen artikel jurnal ini?');">
                  <input type="hidden" name="action" value="delete"/>
                  <input type="hidden" name="id" value={b.id}/>
                  <button class="action-btn danger">Hapus</button>
                </form>
              </td>
            </tr>
          ))}
          {blogs.length === 0 && (
            <tr><td colspan="4" style="text-align:center; color: var(--text-muted); padding: 3rem;">Belum ada artikel yang diterbitkan.</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>

<style>
  .add-new-details {
    padding: 0;
    transition: all 0.3s ease;
  }
  .add-new-details[open] {
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .add-new-summary {
    list-style: none;
    padding: 1.5rem 2rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    user-select: none;
  }
  .add-new-summary::-webkit-details-marker {
    display: none;
  }
  .add-new-content {
    padding: 0 2rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: 0.5rem;
    padding-top: 1.5rem;
    animation: slideDown 0.3s ease-out forwards;
  }
  
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
