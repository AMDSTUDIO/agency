---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Blog, eq } from 'astro:db';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Blog).where(eq(Blog.id, id));
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const category = formData.get('category') as string;
    const author = formData.get('author') as string;
    const img = formData.get('img') as string;
    const excerpt = formData.get('excerpt') as string;
    const content = formData.get('content') as string;
    
    // Astro DB requires a Date object for date columns
    const date = new Date();

    try {
      await db.insert(Blog).values({ id, title, category, date, author, img, excerpt, content });
    } catch (e) {
      console.error(e);
    }
  }
}

const blogs = await db.select().from(Blog);
---

<DashboardLayout title="Manajemen Artikel & Blog">
  <div class="dashboard-action-bar" style="margin-bottom: 2rem;">
    <details class="glass-card add-new-details">
      <summary class="add-new-summary">
        <span style="display: flex; align-items: center; gap: 0.5rem;"><span style="font-size: 1.2rem;">✨</span> Buat Artikel Baru</span>
        <span class="indicator text-muted">Buka editor &darr;</span>
      </summary>
      
      <div class="add-new-content">
        <form method="POST">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
            <div class="form-group">
              <label class="form-label">ID / Slug Unik (contoh: belajar-seo-2024)</label>
              <input type="text" name="id" class="form-input" required />
            </div>

            <div class="form-group">
              <label class="form-label">Judul Artikel Lengkap</label>
              <input type="text" name="title" class="form-input" required />
            </div>

            <div style="display:flex; gap:1rem;">
              <div class="form-group" style="flex:1;">
                <label class="form-label">Topik Kategori</label>
                <input type="text" name="category" class="form-input" required />
              </div>
              <div class="form-group" style="flex:1;">
                <label class="form-label">Nama Penulis</label>
                <input type="text" name="author" class="form-input" value="Admin" required />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">URL Gambar Sampul Resolusi Tinggi</label>
              <input type="url" name="img" class="form-input" required />
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Ringkasan Pendek (Excerpt)</label>
              <textarea name="excerpt" class="form-input" rows="2" placeholder="Tuliskan 1-2 kalimat pemancing rasa penasaran pembaca..." required></textarea>
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Konten Utama (HTML/Teks Bebas)</label>
              <textarea name="content" class="form-input" rows="10" placeholder="Tulis artikel panjang di sini. Anda bisa memakai format tag HTML dasar seperti <p>, <br>, <strong>..." required></textarea>
            </div>
          </div>

          <div style="margin-top: 1.5rem; text-align: right;">
            <button type="submit" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">🚀 Terbitkan Artikel</button>
          </div>
        </form>
      </div>
    </details>
  </div>

  <div>
    <h3 style="margin-bottom: 1.5rem; font-size: 1.2rem; font-weight: 600;">Arsip Jurnal & Artikel</h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
      {blogs.map(b => (
        <div class="data-card glass-card" style="display: flex; flex-direction: column; overflow: hidden; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease;">
          <div style="position: relative; padding-top: 50%;">
            <img src={b.img} alt={b.title} style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" />
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to top, rgba(9,10,15,1) 0%, rgba(9,10,15,0) 100%);"></div>
            <span style="position: absolute; top: 1rem; left: 1rem; background: rgba(99, 102, 241, 0.9); backdrop-filter: blur(5px); padding: 0.3rem 0.8rem; border-radius: 99px; color: #fff; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; box-shadow: 0 4px 10px rgba(0,0,0,0.3);">{b.category}</span>
          </div>
          
          <div style="padding: 1.5rem; display: flex; flex-direction: column; flex: 1; justify-content: space-between; margin-top: -3rem; position: relative; z-index: 2;">
            <div style="margin-bottom: 1.5rem;">
              <h4 style="font-size: 1.2rem; font-weight: 700; color: #fff; line-height: 1.4; margin-bottom: 0.5rem; text-shadow: 0 2px 4px rgba(0,0,0,0.5);">{b.title}</h4>
              <p class="text-muted" style="font-size: 0.9rem; line-height: 1.5;">{b.excerpt}</p>
            </div>
            
            <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.2rem; display: flex; justify-content: space-between; align-items: center;">
              <div style="font-size: 0.8rem; color: var(--text-muted);">
                <span style="display: block; color: rgba(255,255,255,0.8); font-weight: 600;">{b.author}</span>
                {b.date.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' })}
              </div>
              <form method="POST" style="margin:0;" onsubmit="return confirm('Hapus permanen artikel jurnal ini?');">
                <input type="hidden" name="action" value="delete"/>
                <input type="hidden" name="id" value={b.id}/>
                <button class="action-btn danger" style="border-radius: 8px; padding: 0.4rem 1rem;">Hapus</button>
              </form>
            </div>
          </div>
        </div>
      ))}
    </div>

    {blogs.length === 0 && (
      <div class="glass-card" style="text-align:center; color: var(--text-muted); padding: 4rem 2rem; border-style: dashed;">
        <span style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 1rem;">📝</span>
        Belum ada artikel yang diterbitkan. Silakan tulis artikel pertama Anda.
      </div>
    )}
  </div>
</DashboardLayout>

<style>
  .add-new-details {
    padding: 0;
    transition: all 0.3s ease;
  }
  .add-new-details[open] {
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .add-new-summary {
    list-style: none;
    padding: 1.5rem 2rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    user-select: none;
  }
  .add-new-summary::-webkit-details-marker {
    display: none;
  }
  .add-new-content {
    padding: 0 2rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: 0.5rem;
    padding-top: 1.5rem;
    animation: slideDown 0.3s ease-out forwards;
  }
  
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
