---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Portfolio, eq } from 'astro:db';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Portfolio).where(eq(Portfolio.id, id));
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const category = formData.get('category') as string;
    const img = formData.get('img') as string;

    try {
      await db.insert(Portfolio).values({ id, title, category, img });
    } catch (e) {
      console.error(e);
    }
  }
}

const portfolios = await db.select().from(Portfolio);
---

<DashboardLayout title="Manajemen Portfolio">
  <div class="dashboard-action-bar" style="margin-bottom: 2rem;">
    <details class="glass-card add-new-details">
      <summary class="add-new-summary">
        <span style="display: flex; align-items: center; gap: 0.5rem;"><span style="font-size: 1.2rem;">✨</span> Tambah Portfolio Karya</span>
        <span class="indicator text-muted">Buka formulir &darr;</span>
      </summary>
      
      <div class="add-new-content">
        <form method="POST">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
            <div class="form-group">
              <label class="form-label">ID / Slug Unik</label>
              <input type="text" name="id" class="form-input" required />
            </div>

            <div class="form-group">
              <label class="form-label">Judul Proyek</label>
              <input type="text" name="title" class="form-input" required />
            </div>

            <div class="form-group">
              <label class="form-label">Kategori (mis: Web App)</label>
              <input type="text" name="category" class="form-input" required />
            </div>

            <div class="form-group">
              <label class="form-label">URL Gambar Sampul (Unsplash dll)</label>
              <input type="url" name="img" class="form-input" required />
            </div>
          </div>

          <div style="margin-top: 1.5rem; text-align: right;">
            <button type="submit" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">Simpan Portfolio</button>
          </div>
        </form>
      </div>
    </details>
  </div>

  <div>
    <h3 style="margin-bottom: 1.5rem; font-size: 1.2rem; font-weight: 600;">Katalog Portfolio Aktif</h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
      {portfolios.map(p => (
        <div class="data-card glass-card" style="display: flex; flex-direction: column; overflow: hidden; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease;">
          <div style="position: relative; padding-top: 56.25%;">
            <img src={p.img} alt={p.title} style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" />
            <span style="position: absolute; top: 1rem; right: 1rem; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); padding: 0.3rem 0.6rem; border-radius: 99px; color: #fff; font-size: 0.75rem; border: 1px solid rgba(255,255,255,0.1);">{p.id}</span>
          </div>
          
          <div style="padding: 1.5rem; display: flex; flex-direction: column; flex: 1; justify-content: space-between;">
            <div style="margin-bottom: 1rem;">
              <span style="display: inline-block; padding: 0.2rem 0.6rem; background: rgba(99, 102, 241, 0.1); color: #818cf8; border-radius: 6px; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">{p.category}</span>
              <h4 style="font-size: 1.1rem; font-weight: 600; color: #fff; line-height: 1.4;">{p.title}</h4>
            </div>
            
            <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem;">
              <form method="POST" style="margin:0;" onsubmit="return confirm('Hapus permanen portfolio ini?');">
                <input type="hidden" name="action" value="delete"/>
                <input type="hidden" name="id" value={p.id}/>
                <button class="action-btn danger" style="width: 100%; border-radius: 8px;">🗑️ Hapus Proyek</button>
              </form>
            </div>
          </div>
        </div>
      ))}
    </div>

    {portfolios.length === 0 && (
      <div class="glass-card" style="text-align:center; color: var(--text-muted); padding: 4rem 2rem; border-style: dashed;">
        <span style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 1rem;">🖼️</span>
        Belum ada entri portfolio. Silakan tambahkan proyek pertama Anda.
      </div>
    )}
  </div>
</DashboardLayout>

<style>
  .add-new-details {
    padding: 0;
    transition: all 0.3s ease;
  }
  .add-new-details[open] {
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .add-new-summary {
    list-style: none;
    padding: 1.5rem 2rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    user-select: none;
  }
  .add-new-summary::-webkit-details-marker {
    display: none;
  }
  .add-new-content {
    padding: 0 2rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: 0.5rem;
    padding-top: 1.5rem;
    animation: slideDown 0.3s ease-out forwards;
  }
  
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
