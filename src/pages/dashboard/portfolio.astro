---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Portfolio, eq } from 'astro:db';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Portfolio).where(eq(Portfolio.id, id));
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const category = formData.get('category') as string;
    const img = formData.get('img') as string;

    try {
      await db.insert(Portfolio).values({ id, title, category, img });
    } catch (e) {
      console.error(e);
    }
  }
}

const portfolios = await db.select().from(Portfolio);
---

<DashboardLayout title="Manajemen Portfolio">
  <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem;">
    
    <div class="glass-card">
      <h3 class="title-md" style="margin-bottom: 1.5rem; font-size: 1.2rem;">Tambah Portfolio</h3>
      
      <form method="POST">
        <input type="hidden" name="action" value="create"/>
        
        <div class="form-group">
          <label class="form-label">ID / Slug Unik</label>
          <input type="text" name="id" class="form-input" required />
        </div>

        <div class="form-group">
          <label class="form-label">Judul Proyek</label>
          <input type="text" name="title" class="form-input" required />
        </div>

        <div class="form-group">
          <label class="form-label">Kategori (mis: Web App)</label>
          <input type="text" name="category" class="form-input" required />
        </div>

        <div class="form-group">
          <label class="form-label">URL Gambar Sampul</label>
          <input type="url" name="img" class="form-input" required />
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%;">Simpan Portfolio</button>
      </form>
    </div>

    <div class="glass-card table-container">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Gambar</th>
            <th>Judul & Kategori</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          {portfolios.map(p => (
            <tr>
              <td><img src={p.img} alt={p.title} width="60" style="border-radius:5px;" /></td>
              <td><strong>{p.title}</strong><br/><small class="text-muted">{p.category}</small></td>
              <td>
                <form method="POST" style="display:inline;" onsubmit="return confirm('Hapus portfolio ini?');">
                  <input type="hidden" name="action" value="delete"/>
                  <input type="hidden" name="id" value={p.id}/>
                  <button class="action-btn danger">Hapus</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>
