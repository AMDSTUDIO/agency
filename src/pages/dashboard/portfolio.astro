---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Portfolio, eq } from 'astro:db';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const act = formData.get('action');

  if (act === 'delete') {
    const id = formData.get('id') as string;
    await db.delete(Portfolio).where(eq(Portfolio.id, id));
  } else if (act === 'update') {
    const original_id = formData.get('original_id') as string;
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const category = formData.get('category') as string;
    const img = formData.get('img') as string;
    const content = formData.get('content') as string;

    try {
      await db.update(Portfolio).set({ id, title, category, img, content }).where(eq(Portfolio.id, original_id));
    } catch (e) {
      console.error(e);
    }
  } else if (act === 'create') {
    const id = formData.get('id') as string;
    const title = formData.get('title') as string;
    const category = formData.get('category') as string;
    const img = formData.get('img') as string;
    const content = formData.get('content') as string;

    try {
      await db.insert(Portfolio).values({ id, title, category, img, content });
    } catch (e) {
      console.error(e);
    }
  }
}

const portfolios = await db.select().from(Portfolio);
---

<DashboardLayout title="Manajemen Portfolio">
  <div class="dashboard-action-bar" style="margin-bottom: 2rem;">
    <!-- Tambah Portfolio Button -->
    <div class="glass-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-radius: 16px;">
      <div>
        <h4 style="margin: 0 0 0.5rem 0; font-weight: 600;">✨ Tambah Portfolio Karya</h4>
        <p class="text-muted" style="margin: 0; font-size: 0.9rem;">Pamerkan hasil karya agensi Anda ke klien.</p>
      </div>
      <button onclick="document.getElementById('add_modal').showModal()" class="btn btn-primary" style="padding: 0.8rem 2rem; border-radius: 99px; font-weight: 600;">
        ➕ Tambah Proyek
      </button>
    </div>

    <!-- Add Portfolio Modal -->
    <dialog id="add_modal" class="premium-modal" style="max-width: 800px; width: 90%;">
      <div class="modal-header">
        <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; background: linear-gradient(135deg, #fff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Proyek Baru</h3>
        <button type="button" class="close-btn" onclick="document.getElementById('add_modal').close()">&times;</button>
      </div>
      
      <div class="modal-body">
        <form method="POST">
          <input type="hidden" name="action" value="create"/>
          
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Layanan ID (Unik)</label>
              <input type="text" name="id" class="premium-input" placeholder="contoh: re-design-app" required />
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Judul Proyek</label>
              <input type="text" name="title" class="premium-input" placeholder="Contoh: Redesign Aplikasi Bank" required />
            </div>
            
            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Kategori (Sub-judul)</label>
              <input type="text" name="category" class="premium-input" placeholder="mis: Web App • Fintech" required />
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">URL Gambar Sampul (Unsplash dll)</label>
              <input type="url" name="img" class="premium-input" placeholder="https://" required />
            </div>

            <div class="form-group" style="margin: 0;">
              <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Konten/Studi Kasus Lengkap (Mendukung HTML)</label>
              <textarea name="content" class="premium-input" rows="8" placeholder="Ceritakan bagaimana proyek ini dimulai, tantangan, dan hasil akhirnya..."></textarea>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn-cancel" onclick="document.getElementById('add_modal').close()">Batal</button>
            <button type="submit" class="btn-save">Simpan Portfolio</button>
          </div>
        </form>
      </div>
    </dialog>
  </div>

  <div>
    <h3 style="margin-bottom: 1.5rem; font-size: 1.2rem; font-weight: 600;">Katalog Portfolio Aktif</h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
      {portfolios.map(p => (
        <div class="data-card glass-card" style="display: flex; flex-direction: column; overflow: hidden; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease;">
          <div style="position: relative; padding-top: 56.25%;">
            <img src={p.img} alt={p.title} style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" />
            <span style="position: absolute; top: 1rem; right: 1rem; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); padding: 0.3rem 0.6rem; border-radius: 99px; color: #fff; font-size: 0.75rem; border: 1px solid rgba(255,255,255,0.1);">{p.id}</span>
          </div>
          
          <div style="padding: 1.5rem; display: flex; flex-direction: column; flex: 1; justify-content: space-between;">
            <div style="margin-bottom: 1rem;">
              <span style="display: inline-block; padding: 0.2rem 0.6rem; background: rgba(99, 102, 241, 0.1); color: #818cf8; border-radius: 6px; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">{p.category}</span>
              <h4 style="font-size: 1.1rem; font-weight: 600; color: #fff; line-height: 1.4;">{p.title}</h4>
            </div>
            
            <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem; display: flex; gap: 0.5rem;">
              <button type="button" onclick={`document.getElementById('edit_modal_${p.id}').showModal()`} class="action-btn" style="width: 100%; border-radius: 8px; padding: 0.6rem; background: rgba(99,102,241,0.1); color: #818cf8; border: 1px solid rgba(99,102,241,0.2);">✏️ Edit</button>
              <form method="POST" style="margin:0; flex:1;" onsubmit="return confirm('Hapus permanen portfolio ini?');">
                <input type="hidden" name="action" value="delete"/>
                <input type="hidden" name="id" value={p.id}/>
                <button class="action-btn danger" style="width: 100%; border-radius: 8px; height: 100%; padding: 0.6rem;">🗑️ Hapus</button>
              </form>

              <dialog id={`edit_modal_${p.id}`} class="premium-modal" style="max-width: 800px; width: 90%;">
                <div class="modal-header">
                  <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; background: linear-gradient(135deg, #fff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Ubah Portfolio</h3>
                  <button type="button" class="close-btn" onclick={`document.getElementById('edit_modal_${p.id}').close()`}>&times;</button>
                </div>
                
                <div class="modal-body">
                  <form method="POST">
                    <input type="hidden" name="action" value="update"/>
                    <input type="hidden" name="original_id" value={p.id}/>
                    
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Kode ID</label>
                        <input type="text" name="id" class="premium-input" value={p.id} required />
                      </div>

                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Judul Proyek</label>
                        <input type="text" name="title" class="premium-input" value={p.title} required />
                      </div>
                      
                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Kategori</label>
                        <input type="text" name="category" class="premium-input" value={p.category} required />
                      </div>

                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">URL Gambar Sampul</label>
                        <input type="url" name="img" class="premium-input" value={p.img} required />
                      </div>

                      <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Konten/Studi Kasus Lengkap (Mendukung HTML)</label>
                        <textarea name="content" class="premium-input" rows="8">{p.content || ''}</textarea>
                      </div>
                    </div>

                    <div class="modal-footer">
                      <button type="button" class="btn-cancel" onclick={`document.getElementById('edit_modal_${p.id}').close()`}>Batal</button>
                      <button type="submit" class="btn-save">Simpan Perubahan</button>
                    </div>
                  </form>
                </div>
              </dialog>
            </div>
          </div>
        </div>
      ))}
    </div>

    {portfolios.length === 0 && (
      <div class="glass-card" style="text-align:center; color: var(--text-muted); padding: 4rem 2rem; border-style: dashed;">
        <span style="font-size: 3rem; opacity: 0.5; display: block; margin-bottom: 1rem;">🖼️</span>
        Belum ada entri portfolio. Silakan tambahkan proyek pertama Anda.
      </div>
    )}
  </div>
</DashboardLayout>


