---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Service, Portfolio, Testimonial, Blog } from 'astro:db';

const services = await db.select().from(Service);
const portfolios = await db.select().from(Portfolio);
const blogs = await db.select().from(Blog);
const testimonials = await db.select().from(Testimonial);
---

<DashboardLayout title="Statistik & Ikhtisar">
  <div class="welcome-banner" style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(168, 85, 247, 0.1)), url('https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=2000&auto=format&fit=crop') center/cover; position: relative; overflow: hidden; border-radius: 24px; padding: 3rem; margin-bottom: 3rem; border: 1px solid rgba(255,255,255,0.05); box-shadow: 0 20px 40px rgba(0,0,0,0.2);">
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(90deg, #090a0f 10%, transparent 100%);"></div>
    <div style="position: relative; z-index: 2; max-width: 600px;">
      <h2 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; letter-spacing: -0.02em;">Welcome Back, Executive! 👋</h2>
      <p style="color: rgba(255,255,255,0.7); font-size: 1.1rem; line-height: 1.6;">Overview panel ini menuntun Anda mengontrol penuh mahakarya Agensi Anda. Kelola layanan, artikel, dan portfolio dengan latensi secepat kilat berkat mesin Astro DB lokal.</p>
    </div>
  </div>

  <h3 style="font-size: 1.2rem; color: var(--text-muted); margin-bottom: 1.5rem; font-weight: 500;">Sistem Aktif Saat Ini</h3>
  <div class="stats-grid">
    <div class="stat-card glass-card" style="display: flex; align-items: center; justify-content: space-between; padding: 2rem;">
      <div>
        <h3 style="font-size: 0.95rem; color: var(--text-muted); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Layanan</h3>
        <span class="text-gradient stat-num" style="font-size: 3.5rem; font-weight: 800; line-height: 1;">{services.length}</span>
      </div>
      <div style="font-size: 3rem; opacity: 0.5;">🤝</div>
    </div>
    
    <div class="stat-card glass-card" style="display: flex; align-items: center; justify-content: space-between; padding: 2rem;">
      <div>
        <h3 style="font-size: 0.95rem; color: var(--text-muted); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Portfolio</h3>
        <span class="text-gradient stat-num" style="font-size: 3.5rem; font-weight: 800; line-height: 1;">{portfolios.length}</span>
      </div>
      <div style="font-size: 3rem; opacity: 0.5;">💎</div>
    </div>

    <div class="stat-card glass-card" style="display: flex; align-items: center; justify-content: space-between; padding: 2rem;">
      <div>
        <h3 style="font-size: 0.95rem; color: var(--text-muted); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Testimoni</h3>
        <span class="text-gradient stat-num" style="font-size: 3.5rem; font-weight: 800; line-height: 1;">{testimonials.length}</span>
      </div>
      <div style="font-size: 3rem; opacity: 0.5;">💬</div>
    </div>

    <div class="stat-card glass-card" style="display: flex; align-items: center; justify-content: space-between; padding: 2rem;">
      <div>
        <h3 style="font-size: 0.95rem; color: var(--text-muted); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Artikel Blog</h3>
        <span class="text-gradient stat-num" style="font-size: 3.5rem; font-weight: 800; line-height: 1;">{blogs.length}</span>
      </div>
      <div style="font-size: 3rem; opacity: 0.5;">📝</div>
    </div>
  </div>
</DashboardLayout>

<style>
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .stat-card {
    border-radius: 24px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
    background: rgba(15, 20, 30, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  .stat-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    border-color: rgba(99, 102, 241, 0.2);
  }
</style>
