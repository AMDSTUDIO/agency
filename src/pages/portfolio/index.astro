---
import { db, Portfolio } from 'astro:db';
import Layout from '../../layouts/Layout.astro';

const projects = await db.select().from(Portfolio);
---

<Layout title="Katalog Portfolio Kami">
  <div class="portfolio-hero" style={`background: url('https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?q=80&w=2000&auto=format&fit=crop') center/cover no-repeat; height: 60vh; min-height: 400px; display: flex; align-items: flex-end; position: relative;`}>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, var(--hero-overlay) 100%);"></div>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, transparent 100%);"></div>
    <div class="container" style="position: relative; z-index: 2; padding-bottom: 4rem;">
      <span class="category" style={`font-weight: bold; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; display: inline-block; background: var(--bg); padding: 0.5rem 1rem; border-radius: 8px; border: none; color: var(--fg); box-shadow: 0 4px 15px rgba(0,0,0,0.1);`}>Hasil Karya</span>
      <h1 class="title-xl" style="font-size: clamp(2rem, 5vw, 4rem); max-width: 900px; margin-bottom: 1rem;">Portfolio <span class="text-gradient">Unggulan</span></h1>
      <p class="text-muted" style="max-width: 700px; font-size: 1.1rem; line-height: 1.6;">Lihat daftar lengkap mahakarya digital yang pernah kami kerjakan.</p>
    </div>
  </div>

  <div class="container article-container" style="padding-top: 5rem; padding-bottom: 6rem; max-width: 1200px; margin: 0 auto;">

    <div class="portfolio-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
      {projects.map(p => (
        <a href={`/portfolio/${p.id}`} class="portfolio-card glass-card" style="display:block; text-decoration:none; color:inherit; padding: 1.5rem; border-radius: 20px;">
          <div style="width: 100%; height: 250px; overflow: hidden; border-radius: 12px; margin-bottom: 1.5rem;">
             <img src={p.img} alt={p.title} loading="lazy" style="width:100%; height:100%; object-fit:cover;" />
          </div>
          <div>
            <span class="category text-gradient" style="font-weight: bold; text-transform:uppercase; font-size:0.8rem; letter-spacing:0.05em;">{p.category}</span>
            <h3 style="margin-top:0.5rem; font-size: 1.25rem; font-weight: 600; line-height: 1.3;">{p.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
