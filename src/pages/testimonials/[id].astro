---
import { db, Testimonial, eq } from 'astro:db';
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

if (!id) return new Response("Not found", { status: 404 });

const testimonials = await db.select().from(Testimonial).where(eq(Testimonial.id, id as string));
const entry = testimonials[0];

if (!entry) return new Response("Not found", { status: 404 });
---

<Layout title={`Testimoni dari ${entry.name}`}>
  <div class="testimo-hero" style={`background: url('https://images.unsplash.com/photo-1557804506-669a67965ba0?q=80&w=2000&auto=format&fit=crop') center/cover no-repeat; height: 60vh; min-height: 400px; display: flex; align-items: flex-end; position: relative;`}>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, var(--hero-overlay) 100%);"></div>
    <div class="container" style="position: relative; z-index: 2; padding-bottom: 4rem; display: flex; align-items: flex-end; gap: 2rem;">
      <img src={entry.avatar} alt={entry.name} style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 3px solid var(--glass-border); box-shadow: 0 10px 20px rgba(0,0,0,0.2);" />
      <div>
        <span class="category" style={`font-weight: bold; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; display: inline-block; background: var(--bg); padding: 0.3rem 1rem; border-radius: 8px; color: var(--fg); box-shadow: 0 4px 15px rgba(0,0,0,0.1);`}>{entry.role}</span>
        <h1 class="title-xl" style="font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 0;">{entry.name}</h1>
      </div>
    </div>
  </div>

  <div class="container article-container" style="padding-top: 3rem; padding-bottom: 6rem; max-width: 800px; margin: 0 auto;">
    <a href="/testimonials" class="btn btn-outline back-btn" style="margin-bottom: 3rem;">&larr; Kembali ke Daftar Testimoni</a>
    
    <div class="prose body-text" style="font-size: 1.25rem; line-height: 1.9; color: var(--fg); opacity: 0.9; text-align: center;">
      <div class="quote-mark" style="font-size: 4rem; color: var(--primary); opacity: 0.6; line-height: 0; margin-bottom: 1.5rem; display: block;">"</div>
      <p style="margin-bottom: 2rem; font-style: italic;">
        {entry.content}
      </p>
    </div>
    
    <div class="share-box" style="margin-top: 5rem; padding-top: 2rem; border-top: 1px solid var(--glass-border); text-align: center;">
      <h4 style="margin-bottom: 1.5rem; color: var(--fg);">Bagaimana kami bisa membantu Anda hari ini?</h4>
      <a href="/#cta" class="btn btn-primary" style="padding: 1rem 3rem; border-radius: 99px; font-weight: bold;">Mulai Cerita Sukses Anda</a>
    </div>
  </div>
</Layout>

<style is:global>
  .prose p { margin-bottom: 1.5rem; }
  .prose h2, .prose h3 { color: var(--fg); margin-top: 2.5rem; margin-bottom: 1rem; }
</style>
