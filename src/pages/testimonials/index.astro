---
import { db, Testimonial } from 'astro:db';
import Layout from '../../layouts/Layout.astro';

const testimonials = await db.select().from(Testimonial);
---

<Layout title="Kumpulan Testimoni Client">
  <div class="testimo-hero" style={`background: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2000&auto=format&fit=crop') center/cover no-repeat; height: 60vh; min-height: 400px; display: flex; align-items: flex-end; position: relative;`}>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, var(--hero-overlay) 100%);"></div>
    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, var(--bg) 0%, transparent 100%);"></div>
    <div class="container" style="position: relative; z-index: 2; padding-bottom: 4rem;">
      <span class="category" style={`font-weight: bold; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; display: inline-block; background: var(--bg); padding: 0.5rem 1rem; border-radius: 8px; border: none; color: var(--fg); box-shadow: 0 4px 15px rgba(0,0,0,0.1);`}>Bukti Nyata</span>
      <h1 class="title-xl" style="font-size: clamp(2rem, 5vw, 4rem); max-width: 900px; margin-bottom: 1rem;">Apa Kata <span class="text-gradient">Mereka?</span></h1>
      <p class="text-muted" style="max-width: 700px; font-size: 1.1rem; line-height: 1.6;">Kumpulan testimoni jujur dari ragam klien agensi kami.</p>
    </div>
  </div>

  <div class="container article-container" style="padding-top: 5rem; padding-bottom: 6rem; max-width: 1200px; margin: 0 auto;">

    <div class="testimo-grid" style="display: flex; flex-wrap: wrap; gap: 2rem;">
      {testimonials.map(t => (
        <a href={`/testimonials/${t.id}`} class="glass-card testimo-card" style="flex: 1 1 300px; text-decoration:none; color:inherit; display:flex; flex-direction:column; justify-content:space-between; padding:2rem;">
          <p class="content" style="font-size:1.1rem; line-height:1.7; font-style:italic;">"{t.content}"</p>
          <div class="author" style="display:flex; align-items:center; gap:1rem; margin-top:2rem;">
            <img src={t.avatar} alt={t.name} loading="lazy" style="width:50px; height:50px; border-radius:50%; object-fit:cover;" />
            <div class="author-info">
              <h4 style="margin:0; font-size:1rem;">{t.name}</h4>
              <span class="text-muted" style="font-size:0.85rem;">{t.role}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
