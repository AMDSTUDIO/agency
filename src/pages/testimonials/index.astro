---
import { db, Testimonial } from 'astro:db';
import Layout from '../../layouts/Layout.astro';

const testimonials = await db.select().from(Testimonial);
---

<Layout title="Kumpulan Testimoni Client">
  <div class="container" style="padding-top: 8rem; padding-bottom: 4rem;">
    <div class="section-header text-center" style="margin-bottom: 4rem;">
      <h1 class="title-xl">Apa Kata <span class="text-gradient">Mereka?</span></h1>
      <p class="text-muted" style="margin-top: 1rem;">Kumpulan testimoni jujur dari ragam klien agensi kami.</p>
    </div>

    <div class="testimo-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
      {testimonials.map(t => (
        <a href={`/testimonials/${t.id}`} class="glass-card testimo-card" style="text-decoration:none; color:inherit; display:flex; flex-direction:column; justify-content:space-between; padding:2rem;">
          <p class="content" style="font-size:1.1rem; line-height:1.7; font-style:italic;">"{t.content}"</p>
          <div class="author" style="display:flex; align-items:center; gap:1rem; margin-top:2rem;">
            <img src={t.avatar} alt={t.name} loading="lazy" style="width:50px; height:50px; border-radius:50%; object-fit:cover;" />
            <div class="author-info">
              <h4 style="margin:0; font-size:1rem;">{t.name}</h4>
              <span class="text-muted" style="font-size:0.85rem;">{t.role}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
